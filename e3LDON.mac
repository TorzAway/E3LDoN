| --------------------------------------------------------------------------------------------------
| SUB: ForeceSpawnStepReset
| --------------------------------------------------------------------------------------------------
Sub ForeceSpawnStepReset
/if (${Debugging}) /echo Sub ForeceSpawnStepReset Entry

	/message \arForcing LastSwarmed_Step reset to step \ay(\at1\ay)

	|----------------------------------------------------------
	| -- Write STEP 1 to the ini file since we want to set our initial first step for that zone.
	|------------------------------------------
	/call IniChange "Theme" "LastSwarmed_Step" 1
	/delay 20
	|------------------------------------------

/if (${Debugging}) /echo Sub ForeceSpawnStepReset Exit
/return
| --------------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------------
| SUB: CheckMissionSuccess
| --------------------------------------------------------------------------------------------------
Sub CheckMissionSuccess
	/if (${Debugging}) /echo Sub CheckMissionSuccess Entry
	
	/varset Adventure_Progress Adventure ${Window[AdventureRequestWnd].Child[AdvRqst_ProgressLabel].Text} ${Window[AdventureRequestWnd].Child[AdvRqst_ProgressTextLabel].Text}
	/popcustom 15 5 ${Adventure_Progress}
		|--------
		|--- If task is over, get out !
		|-----------------------------------------------
		/message \at - Checking adventure success status.
		/if (${Window[AdventureRequestWnd].Child[AdvRqst_EnterTimeLeftLabel].Text.Length}==0 && ${Window[AdventureRequestWnd].Child[AdvRqst_CompleteTimeLeftLabel].Text.Length}==0) {			
			/message \atLooks like our adventure is over !
			/message \aw<\ar*\ao*\ay*\ag*\at*\au*\am*\ap*\aw> \agMISSION SUCCESS \aw<\ap*\am*\au*\at*\ag*\ay*\ao*\ar*\aw> 
			/call FinishAdventure
		}
		|-----------------------------------------------
		
	/if (${Debugging}) /echo Sub CheckMissionSuccess Exit
/return
| --------------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------------
| SUB: SinglePullMove   Receive: SinglePull_Loc from TARGETSHORTEST
| --------------------------------------------------------------------------------------------------
Sub SinglePullMove(string SinglePull_Loc)

	/if (${Debugging}) /echo Sub SinglePullMove Entry
		
	|----------------------------------------------------------------------------------------------
		
		|------------------------------------------
		/if (!${Me.XTarget[1].ID} && ${CheckBots}) {
			/call GroupDeathChk
			/call GroupManaChk
			/call GroupEndChk
			/if (${UseMerc}) /call CheckMerc
		}		
		|------------------------------------------		
		
		|------------------------------------------
		| Move group to me before next step
		|------------------------------------------
		/message \at - Calling the group to me before moving to the next step . . . . 
		/call GroupWait
		/delay 1s
		|------------------------------------------

		|-----------------------------------------------
		|/echo \arSinglePullMove: \ayTempSpawnPull_Loc=(${SinglePull_Loc})
		|-----------------------------------------------
		/if (${SinglePull_Loc.Length}>0) {
			|--------------------------------------------------------------
			/if (!${Me.Combat} && !${Me.XTarget[1].ID}) {
				|-------------------------------------------------
				|-- USE COMBAT AND AGRO AWARE NavToLoc2 MOVEMENT TO MOB LOCATION FOR SINGLE PULLS !!!
				|-- USE /nav MOVEMENT TO MOB LOCATION FOR SWARM PULLS !!!
				|------------------------------------------------------------------------------------
				/if (${SwarmPull}) {
					/squelch /nav loc ${SinglePull_Loc}
					/delay 7
					/squelch /e3bcgza /nav loc ${SinglePull_Loc}	
					/while (${Navigation.Active}) {
						/call SetLoc
						/call CheckStuck
						/delay 5
					}
				} else {
					/call NavToLoc2 ${SinglePull_Loc}
					/delay 5
					/while (${Navigation.Active}) {
						/call SetLoc
						/call CheckStuck
						/delay 5
					}					
				}
				/delay 7
				/squelch /e3bcgza /nav loc ${SinglePull_Loc}				
				|------------------------------------------------------------------------------------
			}
			|--------------------------------------------------------------
			
			|------------------------------------------------------------------
			| DO NOT CHANGE MOVEMENT METHOD FROM /NAV ID ${Me.ID} FOR BOTS ~!!!
			|------------------------------------------------------------------
			/squelch /e3bca /nav id ${Me.ID}			
			/delay 5
			|----------------------------------------------------------		

			|---------------------------------------------------------------
			| Use the DoClearTargets for SinglePull system instead, of COMBAT
			|---------------------------------------------------------------
			/call DoClearTargets
			/doevents
			/call CheckMissionSuccess
			/delay 10
		}
		|-----------------------------------------------
		| Before we go to next step ...   ECheck if we should loot Corpses.
		/if (${LootCorpse} && !${Me.XTarget[1].ID}) /call CheckForCorpses
		| Before we go to next step ...   EXIT the loop if we have mission success !
		|-----------------------------------------------		
	|/echo Completed all SinglePullMove steps.
	|----------------------------------------------------------------------------------------------
	/delay 10
	/if (${Debugging}) /echo Sub SinglePullMove Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------------
| SUB: SwarmPullStepMove   Receive: SpawnPull_Step from Go2LastSwarmLoc
| --------------------------------------------------------------------------------------------------
Sub SwarmPullStepMove(string SpawnPull_Step)
	/declare x 						int 	local 	${SpawnPull_Step}
	/declare TempSpawnPull_Loc		string 	local	NULL
	
	|--------------------------------------------------------------------
	| SET THE Zone Identifier Numbher to make zone arrays UNIQUE
	|--------------------------------------------------------------------
	/if (${Zone.ID} == ${RoyalObservatory})		/varset ZoneIdentityNum 1
	/if (${Zone.ID} == ${Taskmasters})			/varset ZoneIdentityNum 2
	/if (${Zone.ID} == ${InfernalSanctuary})	/varset ZoneIdentityNum 3
	/if (${Zone.ID} == ${TheSepulcher})  		/varset ZoneIdentityNum 4
	/if (${Zone.ID} == ${ForlornCaverns})  		/varset ZoneIdentityNum 5
	/if (${Zone.ID} == ${EternalAffliction})  	/varset ZoneIdentityNum 6
	/if (${Zone.ID} == ${AislesOfBlood})  		/varset ZoneIdentityNum 7
	/if (${Zone.ID} == ${SilentGallery})  		/varset ZoneIdentityNum 8
	/if (${Zone.ID} == ${AncientAqua}) 			/varset ZoneIdentityNum 9
	|--------------------------------------------------------------------
	
	/if (${Debugging}) /echo Sub SwarmPullStepMove Entry
	/if (${Debugging}) /echo SpawnPull_Loc=(${SpawnPull_Loc}) | SpawnPull_Step=(${SpawnPull_Step})
	
	|----------------------------------------------------------------------------------------------
    /for x ${SpawnPull_Step} to ${LocalStepArray_${Zone.ShortName}_${ZoneIdentityNum}.Size}
		/varset TempSpawnPull_Loc ${LocalStepArray_${Zone.ShortName}_${ZoneIdentityNum}[1,${x}]}
		
		|-----------------------------
		/if (${TempSpawnPull_Loc.Equal[NULL]}) {
			/message \ar The dungeon steps did not load correctly, reloading !
			/call DoSwarmPull
			/delay 10
		}
		|-----------------------------
		
		|------------------------------------------
		/if (!${Me.XTarget[1].ID} && ${CheckBots}) {
			/call GroupDeathChk
			/call GroupManaChk
			/call GroupEndChk
			/if (${UseMerc}) /call CheckMerc
		}		
		|------------------------------------------		
		
		|------------------------------------------
		| Move group to me before next step
		|------------------------------------------
		/message \at - Calling the group to me before moving to the next step . . . . 
		/call GroupWait
		/delay 1s
		|------------------------------------------

		|-----------------------------------------------
		|/echo \arSwarmPullStepMove: \ayTempSpawnPull_Loc=(${TempSpawnPull_Loc})
		|-----------------------------------------------
		/if (${TempSpawnPull_Loc.Length}>0) {
			/message \agNext location to Nav to is: \aySTEP: \ay[\am${x}\ay] of \ay[\am${LocalStepArray_${Zone.ShortName}_${ZoneIdentityNum}.Size}\ay] Coordinates: [\am${TempSpawnPull_Loc}\ay]
			|--------------------------------------------------------------
			|/echo \agARRAY RETURNED DATA for step \ay[${x}]\ag: TempSpawnPull_Loc=(\am${TempSpawnPull_Loc})
			|--------------------------------------------------------------
			/if (!${Me.Combat} && !${Me.XTarget[1].ID}) {
				|-------------------------------------------------
				|-- USE COMBAT AND AGRO AWARE NavToLoc2 MOVEMENT TO MOB LOCATION FOR SINGLE PULLS !!!
				|-- USE /nav MOVEMENT TO MOB LOCATION FOR SWARM PULLS !!!
				|------------------------------------------------------------------------------------
				/if (${SwarmPull}) {
					/squelch /nav loc ${TempSpawnPull_Loc}
					/delay 7
					/squelch /e3bcgza /nav loc ${TempSpawnPull_Loc}
					/while (${Navigation.Active}) {
						/call SetLoc
						/call CheckStuck
						/delay 5
					}
				} else {
					/call NavToLoc2 ${TempSpawnPull_Loc}
					/delay 5
					/while (${Navigation.Active}) {
						/call SetLoc
						/call CheckStuck
						/delay 5
					}					
				}
				/delay 7
				/squelch /e3bcgza /nav loc ${TempSpawnPull_Loc}				
				|------------------------------------------------------------------------------------
			}
			|--------------------------------------------------------------

			|------------------------------------------------------------------
			| DO NOT CHANGE MOVEMENT METHOD FROM /NAV ID ${Me.ID} FOR BOTS ~!!!
			|------------------------------------------------------------------
			/squelch /e3bca /nav id ${Me.ID}			
			/delay 5
			|----------------------------------------------------------		

			|-------------------------------------------------------------------------------------------------------
			|- WRITE: LastSwarmed_Dungeon and LastSwarmed_Step to ini file, to pickup at this point if we break macro.
			|-------------------------------------------------------------------------------------------------------
			/call IniChange "Theme" "LastSwarmed_Dungeon" ${Zone.ShortName}
			/call IniChange "Theme" "LastSwarmed_Step" ${x}
			|-------------------------------------------------------------------------------------------------------

			|---------------------------------------------------------------
			| Use the DoClearTargets for SPawnPull system instead, of COMBAT
			|---------------------------------------------------------------
			/call DoClearTargets
			/doevents
			/call CheckMissionSuccess
			/delay 10
		}
		|-----------------------------------------------
		| Before we go to next step ...   ECheck if we should loot Corpses.
		/if (${LootCorpse} && !${Me.XTarget[1].ID}) /call CheckForCorpses
		| Before we go to next step ...   EXIT the loop if we have mission success !
		|-----------------------------------------------
		
    /next x
	/message Completed all SpawnPull steps.
	|----------------------------------------------------------------------------------------------
	/delay 10
	/if (${Debugging}) /echo Sub SwarmPullStepMove Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Go2LastSwarmLoc     ( Always Call This to pick up From LastSwarmed_Step )
| --------------------------------------------------------------------------------------------
Sub Go2LastSwarmLoc
	/if (${Debugging}) /echo Sub Go2LastSwarmLoc Entry
	|------------------------------------------------------------------------------------------------------------
	|- READ:  LastSwarmed_Dungeon and LastSwarmed_Step from ini file, to pickup at this point if restarted macro.
	|------------------------------------------------------------------------------------------------------------
	/varset LastSwarmed_Dungeon ${Ini[${Settings},Theme,LastSwarmed_Dungeon]}
	/varset LastSwarmed_Step ${Ini[${Settings},Theme,LastSwarmed_Step]}
	|-------------------------------------------------------------------------------------------------------
	|/echo \arGo2LastSwarmLoc: \ayLastSwarmed_Dungeon=(${LastSwarmed_Dungeon}) | LastSwarmed_Step=(${LastSwarmed_Step})	
	|-------------------------------------------------------------------------------------------------------
	/if (${Debugging}) /echo LastSwarmed_Dungeon=(${LastSwarmed_Dungeon}) | LastSwarmed_Step=(${LastSwarmed_Step})	
	/message \agThe last known spawn pull \aySTEP\ag is: \ay[\am${LastSwarmed_Step}\ay]

	|--------------------------------------------------------------------------------------------------------------------------
	| - Call the SwarmPullStepMove function and pass the location and step from INI file 
	| - (The Array Values have already defined from DoSwarmPull)
	| -
	| If we are in same dungeon, pickup from LastSwarmed_Loc .. else..  run the path fresh !
	| SwarmPullStepMove will pick up the path in a loop where the step number will change X in the loop !
	|--------------------------------------------------------------------------------------------------------------------------
	|/echo {Zone.ShortName}=(${Zone.ShortName}) | {Ini.File.Zone.Name}=(${LastSwarmed_Dungeon}) 
	|-----------------------------------------------------------------------
	| Change values to pass STEP 1 if we arent in the last recorded dungeon.
	|-----------------------------------------------------------------------
	/if (!${Zone.ShortName.Equal[${LastSwarmed_Dungeon}]}) {
		/call ForeceSpawnStepReset
	}
	|-----------------------------------------------------------------------
	|/echo \arGo2LastSwarmLoc: \ay/call SwarmPullStepMove ${LastSwarmed_Step}
	|-----------------------------------------------------------------------
	/call SwarmPullStepMove ${LastSwarmed_Step}
	|-----------------------------------------------------------------------

	|--------------------------------------------------------------------------------------------------------------------------	
	/if (${Debugging}) /echo Sub Go2LastSwarmLoc Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: DoSwarmPull		Note: Define The Array Variables and kick off Go2LastSwarmLoc
| --------------------------------------------------------------------------------------------
Sub DoSwarmPull
/if (${Debugging}) /echo Sub DoSwarmPull Entry

/message \agSetting up pathing to \ay[\arSwarm Pull\ay] \agdungeon. . . . . 
/message ==================================================================

