|--------------------------------------------------------
Sub Event_Magical_Presence

	/e3bcaa /doortarget
    /delay 2s
	/e3bcaa /click left door
    /doortarget
    /delay 2s
    /click left door
    /delay 5
    /doevents flush Magical_Presence
/return
|--------------------------------------------------------
|--------------------------------------------------------
Sub Event_Sealed_Off
	/call LeaveTask
	/doevents flush Sealed_Off
/return 
|--------------------------------------------------------
|--------------------------------------------------------
  Sub Event_MissionSuccess
   
	|------------------------------------------------------------------------------
	| Write Success info to INI
	|------------------------------------------------------------------------------
    /popcustom 2 5 ---> MISSION SUCCESS ! ! !  <---
    /message \agUpdating \ay(\am${Settings}\ay)\ao with last adventure completion data.
	
	/if (${Select[${Zone.ID},264,239,229,254,234,249,244,259]}) {
		/varset NextCamp_Num 1
		/varset NextCamp_Theme "Deepest Guk"
	}
	|------------------------------------------------------------------------------
	/if (${Select[${Zone.ID},257,252,275,262,247,237,267,232,242,271]}) {
		/varset NextCamp_Num 2
		/varset NextCamp_Theme "Miragul's Menagerie"
	}
	|------------------------------------------------------------------------------
	/if (${Select[${Zone.ID},233,238,243,248,253,258,263,268,272,276]}) {
		/varset NextCamp_Num 3
		/varset NextCamp_Theme "Mistmoore Catacombs"
	}
	|------------------------------------------------------------------------------
	/if (${Select[${Zone.ID},230,235,240,245,250,255,260,265,269,273]})  {
		/varset NextCamp_Num 4
		/varset NextCamp_Theme "Rujarkian Hills"
	}
	|------------------------------------------------------------------------------
	/if (${Select[${Zone.ID},270,261,241,256,236,231,274,251,266,246]}) {
		/varset NextCamp_Num 5
		/varset NextCamp_Theme "Takish-Hiz"
	}
	|------------------------------------------------------------------------------
    /call IniChange "Theme" "LastCompleted_Num" ${NextCamp_Num}
    /call IniChange "Theme" "LastCompleted_Theme" "${NextCamp_Theme}"
	/call IniChange "Theme" "NextCamp_Bark" "NONE"
    /call IniChange "Theme" "LastCompleted_TimeStamp" "${Time.Date} ${Time.Time24}"
	|------------------------------------------------------------------------------
	
	|Finish Go to Marrs	
	/delay 10
	/e3bca /nav stop
	/e3bca /playmelody stop
	/e3bca /keypress x 
	/delay 6
	/e3bca /stand
	/delay 5
	/e3bca /alt act 511
	/delay 1s
	/e3bca /alt act 511
	/nav stop
	/if (${Select[${Me.Class.ShortName},BRD]}) /playmelody stop
	/keypress x 
	/delay 6
	/stand
	/delay 5
	/alt act 511
	/delay 1s
	/alt act 511
	
	/delay 15s
	/while (${Zone.ID} != ${TempleofMarr}) {
		/delay 5s
		/e3bcaa /alt act 511
		/squelch /e3bcg /keypress forward
	}
    /doevents flush MissionSuccess
  /return
|--------------------------------------------------------
|--------------------------------------------------------
  Sub Event_MissionFailed
	  /popcustom 13 5 ---> MISSION FAILED ! ! !  <---
	  /call FinishAdventure
      /doevents flush MissionFailed
  /return
|--------------------------------------------------------
|--------------------------------------------------------
  Sub Event_MissionOver
	  /popcustom 13 5 ---> MISSION FAILED ! ! !  <---
	  /call FinishAdventure
      /doevents flush MissionOver
  /return
|--------------------------------------------------------  
|--------------------------------------------------------
  Sub Event_BackOffNow
	  /squelch /target clear
	  /backoff
	  /popcustom 5 5 ### BACKING OFF ###
      /doevents flush BackOffNow
  /return  
|--------------------------------------------------------  
|--------------------------------------------------------
  Sub Event_NavMeshReload
	/message \agReloading navmesh for zone: \ay(\am${Zone.Name}\ay)\ag on all toons.
	/squelch /e3bcaa /nav reload
	/delay 1s
    /doevents flush NavMeshReload
  /return  
