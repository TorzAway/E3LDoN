| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: DoClearTargets
| --------------------------------------------------------------------------------------------
Sub DoClearTargets
	/if (${Debugging}) /echo Sub DoClearTargets Entry
	/if (${Me.XTarget[1].ID} || ${Target.ID}) {
		/delay 5
		|/keypress º
		/delay 5
		/ClearTargets stick
		:gotoloopkeepfighting
		/if (${Me.Sitting}) /stand
		/if (!${Target.ID} && ${Me.XTarget[1].ID}) {
			/squelch /e3bca /nav id ${Me.ID}
			|/keypress º
			/delay 5
			/ClearTargets stick
			/delay 20
			/xtarget set 1 ${Me.Name}
			/delay 3
			/xtarget remove
			/delay 3
			}
		/if (${Target.ID} && !${Me.Combat}) {
			/squelch /e3bca /nav id ${Me.ID}
			|/keypress º
			/delay 5
			/ClearTargets stick
			/keypress esc
			/delay 20
			}
		/if (${Target.Type.Find[corpse]}) {
			/keypress esc
			}
		/if (${Target.Distance.Int} > 20) /stick 15
		|-------------------------------------------------------------------
        /if (${Target.ID} && ${Me.Combat} && ${Target.Type.Equal[npc]}) {
			| --- Explosion of Spite
			/if (${SpawnCount[npc radius 50]} >2 && ${Spawn[npc radius 50].Aggressive} && ${Cast.Ready[749]} && ${DoBurns}) {
				/alt act 749
				/if (${DoBurns}) /quickburn
				/if (${DoBurns}) /longburn
				/delay 20
				/goto :gotoloopkeepfighting
				}
			| --- Explosion of Hatred
			/if (${SpawnCount[npc radius 50]} >4 && ${Spawn[npc radius 50].Aggressive} && ${Cast.Ready[822]} && ${DoBurns}) {
				/alt act 822
				/if (${DoBurns}) /fullburn
				/delay 20
				/goto :gotoloopkeepfighting
				}
			| --- Projection of Doom
			/if (${SpawnCount[npc radius 50]} >6 && ${Spawn[npc radius 50].Aggressive} && ${Cast.Ready[3215]} && ${DoBurns}) /alt act 3215
			| --- EpicBurn
			/if (${SpawnCount[npc radius 50]} >4 && ${Spawn[npc radius 50].Aggressive} && ${DoBurns}) /epicburn
			| --- Vicious Bite of Chaos
			/if ((${Me.PctHPs} < 95) && ${Cast.Ready[825]} && ${DoBurns})  /alt act 825
			| --- Chattering Bones
			/if (${Cast.Ready[3822]} && ${DoBurns}) /alt act 3822
			| --- Encroaching Darkness
			/if ((${SpawnCount[npc radius 50]} <3) && ${Spawn[npc radius 50].Aggressive} && ${Cast.Ready[826]} && ${DoBurns}) {
				/squelch /e3bca /nav target
				/assistme
				/alt act 826
				}
            /delay 2s
            /if (${Debugging}) /echo DEBUG: KillMob: Combat Loop

            /goto :gotoloopkeepfighting
        }
		|-------------------------------------------------------------------
		/if (${Me.XTarget[1].ID} || ${Target.ID}) /goto :gotoloopkeepfighting
	}
	/delay 20
	/if (${Debugging}) /echo Sub DoClearTargets Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: FinishAdventure
| --------------------------------------------------------------------------------------------
Sub FinishAdventure

	/if (${Debugging}) /echo Sub FinishAdventure Entry
	|------------------------------------------------------------------------------
	| Write Success info to INI
	|------------------------------------------------------------------------------
    /popcustom 15 5 ---> MISSION SUCCESS <---
    /message \agUpdating \ay(\am${Settings}\ay)\ao with last adventure completion data.
	
	/if (${Select[${Zone.ID},264,239,229,254,234,249,244,259]}) {
		/varset NextCamp_Num 1
		/varset NextCamp_Theme "Deepest_Guk"
	}
	|------------------------------------------------------------------------------
	/if (${Select[${Zone.ID},257,252,275,262,247,237,267,232,242,271]}) {
		/varset NextCamp_Num 2
		/varset NextCamp_Theme "Miraguls_Menagerie"
	}
	|------------------------------------------------------------------------------
	/if (${Select[${Zone.ID},233,238,243,248,253,258,263,268,272,276]}) {
		/varset NextCamp_Num 3
		/varset NextCamp_Theme "Mistmoore_Catacombs"
	}
	|------------------------------------------------------------------------------
	/if (${Select[${Zone.ID},230,235,240,245,250,255,260,265,269,273]})  {
		/varset NextCamp_Num 4
		/varset NextCamp_Theme "Rujarkian_Hills"
	}
	|------------------------------------------------------------------------------
	/if (${Select[${Zone.ID},270,261,241,256,236,231,274,251,266,246]}) {
		/varset NextCamp_Num 5
		/varset NextCamp_Theme "Takish-Hiz"
	}
	|------------------------------------------------------------------------------
    /call IniChange "Theme" "LastCompleted_Num" ${NextCamp_Num}
    /call IniChange "Theme" "LastCompleted_Theme" "${NextCamp_Theme}"
	/call IniChange "Theme" "NextCamp_Bark" "NONE"
	/call IniChange "Theme" "LastCompleted_TimeStamp" "${Time.Date} ${Time.Time24}"
	/call IniChange "Theme" "LastSwarmed_Step" 1
	|------------------------------------------------------------------------------
	
	|-----------------------------------------------
	| Before we leave ...   Check if we should loot Corpses.
	/if (${LootCorpse} && !${Me.XTarget[1].ID}) /call CheckForCorpses
	|-----------------------------------------------	
	
	| -- *** --
	/call GoToMarrs
	/call GetAdventureStatus
	/call GotoTask
	| -- *** --
	
	/if (${Debugging}) /echo Sub FinishAdventure Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: DoSinglePull
| --------------------------------------------------------------------------------------------
Sub DoSinglePull
	/if (${Debugging}) /echo DoSinglePull Sub Entry
	
	|-------------------
	/call TargetShortest_LDON	
	|/message \atMy Target: \ay[\ap${Spawn[id ${myTargetID}].Name}\ay] [\ap${myTargetIDLoc}\ay]
	|-------------------	
	
	/call SinglePullMove ${myTargetIDLoc}
	/delay 5
	
	/if (${Debugging}) /echo DoSinglePull Sub Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: DoSingleMob
| --------------------------------------------------------------------------------------------
Sub DoSingleMob(string Enemy)
	/if (${Debugging}) /echo DoSingleMob Sub Entry
	|-------------------------
	/call CheckCasting
	|-------------------------
	/varset CampX ${Me.X}
	/varset CampY ${Me.Y}
	/varset CampZ ${Me.Z}
	|--------------------
	/if (${Bool[${Enemy}]}) {
		/varset FarmMob ${Enemy}
		/if (${Debugging} && !${reportTarget}) {
			/message Looking for: ${FarmMob}
			/varset reportTarget ${reportTarget.OriginalValue}
		}
	} else /if (!${reportTarget}) {
		/message \arAttacking \ay[\apAnything I can get my grubby paws on\ay]\ar.
		/varset reportTarget ${reportTarget.OriginalValue}
		|--------------------
		/if (${myTargetID} && !${Target.Type.Equal[Corpse]} && !${Target.Type.Equal[Pet]} && !${Target.Type.Equal[PC]}) {
			/if (${Spawn[id ${Target.ID}].Distance} > 30) /squelch /nav id ${Target.ID}
			|--------------------
			/if (${Me.XTarget[1].ID} && ${Spawn[id ${Target.ID}].Distance} < 30) {
				/if (${Target.ID}) /face
				/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
				/squelch /attack on
				/if (${Select[${Me.Class.ShortName},SHD,MAG,NEC,BST,SHM,ENC,DRU]} && ${Me.Pet.ID}) /pet attack
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}
			|--------------------
			/varcalc BackUpTimer (${BackUpTimer})+1
			|--------------------
			/if (${BackUpTimer}>7) {
				/message \ayHaving trouble getting to a target.. Attempting to get back on mesh.
				/if (${Debugging}) /echo Setting BackUpTimer Plus 1
				/call BackUp
				/varset BackUpTimer 0
			}
			|--------------------
			/if (${AssistMe}) {
				/if (${Debugging}) /e3bcg (Line: ${Macro.CurLine}) killthis
				/squelch /e3bcg /nav id ${Me.ID}
				/squelch /e3bcg /target id ${Me.XTarget[1].ID}
				/timed 10 /squelch /e3bcg /pet attack
				/timed 15 /squelch /e3bcg /pet swarm
				/timed 20 /squelch /e3bcg /assistme
			}	
			|--------------------
		}
		|--------------------
	}
	|--------------------
	
	:findMob
	/if (${Debugging}) /echo FindMob DoSingleMob
	/if (${Target.Type.Equal[corpse]}) {
		/if (${Target.ID} == ${myTargetID}) /varset myTargetID 0
		/squelch /target clear
	}
	/if (${Window[RespawnWnd].Open}) /call GroupDeathChk
	/if (!${Me.XTarget[1].ID} && ${CheckBots}) {
		/call GroupDeathChk
		/call GroupManaChk
		/call GroupEndChk
	}
	/if (${Debugging}) /echo \aymyTargetID has an ID: ${Spawn[id ${myTargetID}].ID} - is a corpse: ${Spawn[id ${myTargetID}].Type.Equal[Corpse]} - I have an XTarget: !${Me.XTarget[1].ID}
	/if (!${Spawn[id ${myTargetID}].ID} || ${Spawn[id ${myTargetID}].Type.Equal[Corpse]} && !${Me.XTarget[1].ID} && !${Me.Casting.ID}) {
		/message \ay"Looking for a target!"
		/varset myTargetID 0
		|-------------------
		/call TargetShortest_LDON
		|-- /message \atMy Target: \ay[\ap${Spawn[id ${myTargetID}].Name}\ay] [\ap${myTargetIDLoc}\ay]		
		|/delay 1s
		|/echo \atMy Target: \ay[\ap${Spawn[id ${myTargetID}].Name}\ay]
		|-------------------
	} else {
		/if (${Debugging}) /echo \ayI have an XTarget so I'm going to set that as my target.
		|---------------------------------------
		/if (${Me.XTarget[1].ID}) {
			/varset myTargetID ${Me.XTarget[1].ID}
			/if (${Debugging}) /echo CALL DoClearTargets
			/if (${Me.XTarget[1].ID} && ${Spawn[id ${Target.ID}].Distance} < 30) /call DoClearTargets
			/if (${Debugging}) /echo END CALL DoClearTargets			
		}
		|---------------------------------------
	}
	:navto
	/if (${Debugging}) /echo DoSingleMob NAVTO
	/if (${Target.ID}) /squelch /target clear
	/if (${Spawn[${myTargetID}].Distance} > 30 && !${Target.Type.Equal[corpse]} && !${Me.XTarget[1].ID} && !${Spawn[${myTargetID}].LineOfSight}) {
		/if (!${Spawn[${myTargetID}].ID}) {
			/squelch /target clear
			/if (${Debugging}) /echo \ar My target ID was null, so I'm returning out of the sub.
			/return
		}
		/varset BackUpTimer 0
		/message \agNavigating to: \ay[\ap${Spawn[${myTargetID}].CleanName}\ay] \agID: \ay[\ap${myTargetID}\ay] \agDistance: \ay[\ap${Spawn[${myTargetID}].Distance}\ay]
		/if (${Debugging}) /echo \ayNavigating to ${Spawn[${myTargetID}].Name} ID: ${myTargetID} Distance: ${Spawn[${myTargetID}].Distance} > 30 - Line of Sight: ${Spawn[${myTargetID}].LineOfSight}
		/call WaitNav ${myTargetID}
		/delay 10
		/if (${Debugging}) /echo Navigating to the enemy.
		/call SetLoc
		/call CheckStuck
		/delay 5
		/goto :navto
	} else /if (!${Target.ID} || ((${Target.ID}!=${myTargetID}) && (${Target.ID}!=${Me.ID}) && (${myTargetID}!=0) && !${Me.XTarget[1].ID})) {
		/target id ${myTargetID}
		/if (${Navigation.Active}) /nav stop
	}
	/delay 5
	|-----------------------------------------------
	/if (${Debugging}) /echo DoSingleMob Sub Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: TargetShortest
| --------------------------------------------------------------------------------------------
Sub TargetShortest_LDON

	/if (${Debugging}) /echo Sub TargetShortest_LDON Entry
	/if (${UseClickBuffs}) /call Clickies_Buffs
	/declare MobsInRadius 	int 	local 	${SpawnCount[npc noalert 1 targetable radius ${CampRadius} zradius ${ZRadius} alert 10]}
	
	|----------------------------------------------
	|- Makes scanning in big zones super efficient.
	|----------------------------------------------
	/if (${MobsInRadius} > 5) {
		/varset MobsInRadius 5
	}
	|----------------------------------------------
	
	/declare MobCounter 	int 	local 	0
	/declare MobID 			int 	local 	0
	/declare PathLength		float	local	0
	/declare MobIDDistance	float	local	0
	/declare PathCount		int		local	1
	/declare PathShortest	int 	local 	0
	/declare MobIDValid		int		local	0

	/varset myTargetID 0
	
	/if (${MobsInRadius}) {
		/for MobCounter 1 to ${MobsInRadius}
		/varset MobID ${NearestSpawn[${MobCounter},npc targetable radius ${CampRadius} zradius ${ZRadius} alert 10 noalert 1].ID}

		|------- HARD CODED EXCEPTIONS
		/if (${Select[${Spawn[ID ${MobID}].Type},PET,AURA,BANNER,CAMPFIRE,CORPSE,CHEST,ITEM,TRIGGER,TRAP,TIMER,MOUNT,MERCENARY,OBJECT]} && !${Ini[${MobIgnore},${Zone.ShortName},Ignored].Find[ID ${MobID}]}) /continue
		/if (${Spawn[ID ${MobID}].Surname.Length}) /continue
		/if (${Spawn[ID ${MobID}].CleanName.Equal[a hatchling]} || ${Spawn[ID ${MobID}].CleanName.Equal[a creaking crate]} || ${Spawn[ID ${MobID}].CleanName.Equal[a hollow tree]} || ${Spawn[ID ${MobID}].CleanName.Equal[a petrified colossal tree]}) {
			/continue
		}
		|------- HARD CODED EXCEPTIONS

		/varset MobIDValid 0
		/varset PathLength ${Navigation.PathLength[id ${MobID}]}
		
		|--------------------------
		/if (${PathLength} > 0) {
			/if (${PathCount}==1) {
				/varset myTargetID ${MobID}
				/varset myTargetIDLoc "${Spawn[id ${myTargetID}].Y} ${Spawn[id ${myTargetID}].X} ${Spawn[id ${myTargetID}].Z}"
				/varset PathShortest ${PathLength}
			} else /if (${PathLength} <= ${PathShortest}) {
				/varset myTargetID ${MobID}
				/varset myTargetIDLoc "${Spawn[id ${myTargetID}].Y} ${Spawn[id ${myTargetID}].X} ${Spawn[id ${myTargetID}].Z}"
				/varset PathShortest ${PathLength}
			}
			/varcalc PathCount ${PathCount}+1 
		}
		|--------------------------
		
		/next MobCounter
		/if (${myTargetID}) /message \agPulling:\ay[\ap${Spawn[${myTargetID}].CleanName}\ay] \agNPCID:\ay[\ap${myTargetID}\ay] \ar| \awat \ay[\at${PathShortest}\ay] \awfeet \ar| \agLOC:\ay[\ap${Spawn[id ${myTargetID}].Y} ${Spawn[id ${myTargetID}].X} ${Spawn[id ${myTargetID}].Z}\ay]
		/varset Announce FALSE
		/varset notkillable 0
	} else {
		/varset myTargetID 0
		/delay 5s ${Me.XTarget} == 0
		/if (!${Me.XTarget}) {
			/if (!${Announce}) {
				/message No more mobs to pull, lets Wait for Respawn!
				/varset Announce TRUE
			}
			/varset notkillable 0
			/if (${Me.Standing} && !${Navigation.Active}) /sit
		}
		/if (${Me.XTarget}) /return
	}
	/delay 1
	
	/varcalc BackUpTimer (${BackUpTimer})+1
	/if (${Debugging}) /echo Setting BackUpTimer +1 to ${BackUpTimer}
	/if (${Debugging} && ${BackUpTimer}>1) /echo \arCould Be Stuck ${BackUpTimer}
	|-----------------------
	/if (${BackUpTimer}>10) {
		/message \ayHaving trouble getting to a target.. Attempting to get back on mesh.
		/if (${Debugging}) /echo Setting BackUpTimer Plus 1
		/call BackUp
		/varset BackUpTimer 0
	}
	|-----------------------
	/if (${Debugging}) /echo Sub TargetShortest_LDON Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Clickies_Damage
| --------------------------------------------------------------------------------------------
Sub Clickies_Damage
	/if (${Debugging}) /echo Sub Clickies_Damage Entry
|Clicky Pet
	/if (${Me.ItemReady[Amulet of the Drowned Marriner]}) {
			/useitem Amulet of the Drowned Marriner
			/delay 1s
			/message \agActivating \ay[\apAmulet of the Drowned Marriner\ay]
			/delay 1s !${Me.ItemReady[Amulet of the Drowned Marriner]}
		}
|Clicky Pet
	/if (${Me.ItemReady[Dancing Shard of Ice]}) {
			/useitem Dancing Shard of Ice
			/delay 1s
			/message \agActivating \ay[\apDancing Shard of Ice\ay]
			/delay 1s !${Me.ItemReady[Dancing Shard of Ice]}
		}
|Clicky Pet
	/if (${Me.ItemReady[Vicious Rabbit]}) {
			/useitem Vicious Rabbit
			/delay 1s
			/message \agActivating \ay[\apVicious Rabbit\ay]
			/delay 1s !${Me.ItemReady[Vicious Rabbit]}
		}
|Ring Dot
	/if (${Me.ItemReady[Ring of Ill Touch]}) {
			/useitem Ring of Ill Touch
			/delay 1s
			/message \agActivating \ay[\apRing of Ill Touch\ay]
			/delay 1s !${Me.ItemReady[Ring of Ill Touch]}
		}
/if (${Debugging}) /echo Sub Clickies_Damage Exit		
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Clickies_Buffs
| --------------------------------------------------------------------------------------------
Sub Clickies_Buffs
/if (${Debugging}) /echo Sub Clickies_Buffs Entry
|Clicky Buff
	/if (${Me.ItemReady[Ice Encrusted Cloak of Adroitness]} && !${Me.Buff[Illusionary Spikes XXIV].ID}) {
			/useitem Ice Encrusted Cloak of Adroitness
			/delay 1s
			/message \agActivating \ay[\apIce Encrusted Cloak of Adroitness\ay]
			/delay 1s !${Me.ItemReady[Ice Encrusted Cloak of Adroitness]}
		}
|Clicky Buff
	/if (${Me.ItemReady[Ice Encrusted Charm of Vigor]} && !${Me.Buff[Geomantra XXIV].ID}) {
			/useitem Ice Encrusted Charm of Vigor
			/delay 1s
			/message \agActivating \ay[\apIce Encrusted Charm of Vigor\ay]
			/delay 1s !${Me.ItemReady[Ice Encrusted Charm of Vigor]}
		}
|Clicky Illusion
	/if (${Me.ItemReady[Amulet of Necropotence]} && !${Me.Buff[Illusion: Skeleton].ID}) {
			/useitem Amulet of Necropotence
			/delay 1s
			/message \agActivating \ay[\apAmulet of Necropotence\ay]
			/delay 1s !${Me.ItemReady[Amulet of Necropotence]}
		}
|Clicky Boots
	/if (${Me.ItemReady[Fabled Journeyman's Boots]} && !${Me.Buff[Bootstrutter's Blessing].ID} && !${Me.Buff[Flight of Falcons].ID} && !${Me.Buff[Spirit of Wolf].ID} && !${Me.Buff[Spirit of Bih'Li].ID} && !${Me.Buff[Spirit of Tala'Tak].ID} && !${Me.Buff[Flight of Eagles].ID}) {
			/useitem Fabled Journeyman's Boots
			/delay 1s
			/message \agActivating \ay[\apFabled Journeyman's Boots\ay]
			/delay 1s !${Me.ItemReady[Fabled Journeyman's Boots]}
		}
	/if (${Debugging}) /echo Sub Clickies_Buffs Exit		
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Zoning
| --------------------------------------------------------------------------------------------
Sub Zoning
	/if (${Debugging}) /echo Sub Zoning Entry
	:Zoning
	/delay 2m ${Zone.ID}!=${startZone}
	/target id ${Me.ID}
	/delay 1s ${Target.ID}==${Me.ID}
	/if (!${Navigation.MeshLoaded}) {
		/message \ayWaiting for you to load a mesh for this zone.
		/nav reload
		/delay 5s
		/goto :Zoning
	}
	/delay 2s
	/varset startZone ${Zone.ID}
	/squelch /target clear
	/call CheckMesh
	/delay 2s
	|---------------------------------------------
	| Cleartargets if I have agro on zoning.
	|---------------------------------------------
	/if (${Me.XTarget[1].ID}) /Call DoClearTargets
	/call Refresh
	/if (${Debugging}) /echo Sub Zoning Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GroupWait
| --------------------------------------------------------------------------------------------
Sub GroupWait
/if (${Debugging}) /echo Sub GroupWait Entry
:WaitForGroup
/if (${Me.XTarget[1].ID}) {
	/if (${Navigation.Active}) /nav stop
	/call Group2Me
	/call DoClearTargets
	/goto :WaitForGroup
}
/message \ayWaiting for the group. . .

/if (${Debugging}) /echo ${Group.Member[1].CleanName}:(${Group.Member[1].Distance}) ${Group.Member[2].CleanName}:(${Group.Member[2].Distance}) ${Group.Member[3].CleanName}:(${Group.Member[3].Distance}) ${Group.Member[4].CleanName}:(${Group.Member[4].Distance}) ${Group.Member[5].CleanName}:(${Group.Member[5].Distance})

    /while ((${Group.Member[1].Distance} > 40) || (${Group.Member[2].Distance} > 40) || (${Group.Member[3].Distance} > 40) || (${Group.Member[4].Distance} > 40) || (${Group.Member[5].Distance} > 40) || (${Group.Member[6].Distance} > 40)) {
        /message \aywaiting for the group, timer ${GroupWaitTimer}.\ax
		/e3bca /stand
		/e3bca /nav id ${Me.ID}
        /delay 5s
		/varcalc GroupWaitTimer (${GroupWaitTimer})+1
		/call GroupWaitTimer
		/goto :WaitForGroup
	}
	/varset GroupWaitTimer 0
	/message \ay. . . my group is now here.\ax
	/if (${Debugging}) /echo Sub GroupWait Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GroupWaitTimer
| --------------------------------------------------------------------------------------------
Sub GroupWaitTimer
	/if (${Debugging}) /echo Sub GroupWaitTimer Entry
	/if (${GroupWaitTimer}==8) /varset GroupWaitTimer 0
	/if (${GroupWaitTimer}==5) {
		/message \ayA Group Member might be stuck!
		/squelch /e3bcaa /stand
		/squelch /e3bcaa /removelev
		/squelch /e3bcaa /moveto loc ${Me.Y} ${Me.X} ${Me.Z}
		/squelch /e3bcaa /keypress back hold
		/delay 3s
		/squelch /e3bcaa /keypress back
	}
	/if (${GroupWaitTimer}==6) {
		/message \ayA Group Member is stuck!
		/squelch /e3bcaa /moveto loc ${Me.Y} ${Me.X} ${Me.Z}
		/squelch /e3bcaa /keypress forward hold
		/delay 2s
		/squelch /e3bcaa /keypress forward
		/delay 2s
	}
	|--- Use Wayfarers Brotherhood Emblem' to COTH the group.
	/if (${GroupWaitTimer}==7 && ${FindItemCount[Wayfarers Brotherhood Emblem]}>0) {
		/message \ayA Group Member is stuck, Attempting to CoH !!!
		/delay 1s
		/coth group
		/delay 1s
		/call CheckCasting
		/delay 5
	}
	/if (${Debugging}) /echo Sub GroupWaitTimer Exit
/return GroupWaitTimer
|--------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: ResetBard
| --------------------------------------------------------------------------------------------
Sub ResetBard
	/if (${Debugging}) /echo Sub ResetBard Entry
	/message \agPerforming Bard Reset !\ax

	/declare x 					int 	local	1

	|--- BRDMelodyName

	/for x 1 to ${Group.Members}
		/if (${Group.Member[${x}].Class.ShortName.Equal[BRD]}) {
		|-----------------------------------------
		/while (${Group.Member[${x}].OtherZone}) {
			:WaitForBardToZoneIn
				/message \ay - [\am${Group.Member[${x}].CleanName}\ay] is \arNOT IN ZONE\ax yet, waiting.
				/delay 3s
				/if (${Group.Member[${x}].OtherZone}) /goto :WaitForBardToZoneIn
		}
		|-----------------------------------------
		/message \ayResetting E3 [\atBRD\ay] MELODY for [\am${Group.Member[${x}].CleanName}\ay].
		|------------------------
		|/squelch /e3bct ${Group.Member[${x}].CleanName} /mono E3
		/squelch /e3bct ${Group.Member[${x}].CleanName} /playmelody ${BRDMelodyName}
		/delay 3s
	}
	/next x

	/if (${Debugging}) /echo Sub ResetBard Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckInvis
| --------------------------------------------------------------------------------------------
Sub CheckInvis
	/if (${Debugging}) /echo Sub CheckInvis Entry

	/declare y 					int 	local	0

	:CheckInvisNow
	|------------
	/if (!${Me.Combat} && !${Me.XTarget[1].ID}) /call Group2Me
	|------------
		
	|-----------------------------	
	/for y 1 to ${Group.Members}
		|/echo Checking if ${Group.Member[${y}].CleanName} is close.
		/if (${Group.Member[${y}].Distance}>20) {			
			:MemberDistanceInvisCheck
			/message \ay- \am[\ag${Group.Member[${y}].CleanName}\am]\ay is \am[\ao${Group.Member[${y}].Distance}\am]\ay paces away still.
			|------------------------
			/delay 5 ${Group.Member[${y}].Distance}<20
			/if (${Group.Member[${y}].Distance}>20) /goto :MemberDistanceInvisCheck
			|------------------------
		}
	/next y
	|-----------------------------		
	
	|-----------------------------	
	| -- DELAY TO MAKE SURE GROUP STOPPED BEFORE ATTEMPTING TO CAST INVIS !
	|-----------------------------
	/delay 1s
	/for y 0 to ${Group.Members}
		|/echo Checking if ${Group.Member[${y}].CleanName} is Moving.
		/if (${Group.Member[${y}].Moving}) {
			/message \ay- \am[\ag${Group.Member[${y}].CleanName}\am]\ay is Moving.... waiting.
			:MemberMovingInvisCheck
			|------------------------
			/delay 5 !${Group.Member[${y}].Moving}
			/if (${Group.Member[${y}].Moving}) /goto :MemberMovingInvisCheck
			|------------------------
		}
	/next y
	|-----------------------------	
	| -- DELAY TO MAKE SURE GROUP STOPPED BEFORE ATTEMPTING TO CAST INVIS !
	|-----------------------------

	|----------------------------------------------------------------------------
	|--- REFERENCE ----
	|----------------------------------------------------------------------------
	|------------- INDIVIDUAL OR UNDEAD ---------------
	|/squelch /e3bcg /alt act 1212 	; -- Group Perfected Invisibility to Undead  -- Cleric / Necromancer / Paladin / Shadowknight
	|/squelch /e3bcg /alt act 280 	; -- Group Perfected Invisibility to Undead -- Magician / Enchanter / Wizard
	|/squelch /e3bcg /alt act 231 	; -- Shauri's Sonorious Clouding -- Bard AA
	|/squelch /e3bcg /alt act 531 	; -- Cloak of Shadows -- Necromancer / Shadow Knight
	|/squelch /e3bcg /alt act 8301 	; -- Improved Natural Invisibility -- Beastlord
	|------------- GROUP ---------------
	|/squelch /e3bcg /alt act 630 	; -- Group Silent Presence -- Shaman
	|/squelch /e3bcg /alt act 518 	; -- Shared Camouflage -- Druid / Ranger
	|/squelch /e3bcg /alt act 1210 	; -- Group Perfect Invisibility -- Magician / Enchanter / Wizard
	|----------------------------------------------------------------------------

	|----------------------- IF ME !INVIS
	/if (!${Me.Invis}) {
		/message \arNeed to make myself invisible!
		/message \ayAttempting to invis group using alternate abilities !
		|------------------------------------
		|------------- UNDEAD ---------------
		|/if (!${Me.Invis}) /call DoGrpInvisByClass CLR 1212
		|/if (!${Me.Invis}) /call DoGrpInvisByClass PAL 1212
		|/if (!${Me.Invis}) /call DoGrpInvisByClass NEC 1212
		|/if (!${Me.Invis}) /call DoGrpInvisByClass SHD 1212
		|------------- UNDEAD ---------------
		|/if (!${Me.Invis}) /call DoGrpInvisByClass MAG 280
		|/if (!${Me.Invis}) /call DoGrpInvisByClass ENC 280
		|/if (!${Me.Invis}) /call DoGrpInvisByClass WIZ 280
		|------------- GROUP ---------------
		/if (!${Me.Invis}) /call DoGrpInvisByClass SHM 630
		|------------- GROUP ---------------
		/if (!${Me.Invis}) /call DoGrpInvisByClass DRU 518
		/if (!${Me.Invis}) /call DoGrpInvisByClass RNG 518
		|------------- GROUP ---------------
		/if (!${Me.Invis}) /call DoGrpInvisByClass ENC 1210
		/if (!${Me.Invis}) /call DoGrpInvisByClass MAG 1210		
		/if (!${Me.Invis}) /call DoGrpInvisByClass WIZ 1210
		|------------- INDIVIDUAL ---------------
		|/if (!${Me.Invis}) /call DoGrpInvisByClass BRD 231
		/if (!${Me.Invis}) /call DoGrpInvisByClass SHD 531
		/if (!${Me.Invis}) /call DoGrpInvisByClass NEC 531
		/if (!${Me.Invis}) /call DoGrpInvisByClass BST 8301
		|------------------------------------
		/delay 3s ${Me.Invis}
	}
	|----------------------- IF ME !INVIS
				
	|----------------------- IF ME !INVIS
	/if (!${Me.Invis}) {
		/message \arNeed to make myself invisible!
		/message \ayI am \arSTILL NOT\ay invised, checking for a \am[\atBRD\am]\ay in group to invis.
		|-----------------------------
		/for y 1 to ${Group.Members}
			/if (${Group.Member[${y}].Class.ShortName.Equal[BRD]}) {
				/message \ay[\am${Group.Member[${y}].CleanName}\ay] is a [\atBRD\ay], making them sing invis !
				|------------------------
				/squelch /e3bct ${Group.Member[${y}].CleanName} /playmelody stop
				/delay 1s
				/squelch /e3bct ${Group.Member[${y}].CleanName} /memspell ${BRDTravelSongSlot} ${BRDTravelSong}
				/delay 3s
				:CheckBrdInvisNow
				/if (!${Me.Invis}) {
					/squelch /e3bct ${Group.Member[${y}].CleanName} /cast ${BRDTravelSongSlot} ${BRDTravelSong}
					/delay 3s
					/message \agWaiting for invis to kick in .....
					/delay 5s ${Me.Invis}
					/goto :CheckBrdInvisNow
				} else {
					/varset y ${Group.Members}
				}
				|------------------------
			}
		/next y
		|-----------------------------
		/delay 3s ${Me.Invis}
	}
	|----------------------- IF ME !INVIS				
		
	|----------------------- IF ME !INVIS
	/if (!${Me.Invis}) {
			/message \arNeed to make myself invisible!
			/message \ayI am \arSTILL NOT\ay invised, attempting \atlast resort\ay !
			|-----------------------------
			/if (${Me.Class.ShortName.Equal[NEC]} || ${Me.Class.ShortName.Equal[SHD]}) {
				/if (${Me.AltAbility[Cloak of Shadows]}) {
					/alt act ${Me.AltAbility[Cloak of Shadows]}
				} else /if (${FindItemCount[Cloudy Potion]}) {
					/casting "Cloudy Potion|Item"
				} else /if (${Me.ItemReady[Circlet of Shadows]} && !${Me.Buff[Gather Shadows].ID}) {
					/useitem Circlet of Shadows
					/delay 1s
					/message \agActivating \ay[\apCirclet of Shadows\ay]
					/delay 1s !${Me.ItemReady[Circlet of Shadows]}
				} else /if (${FindItemCount[Cloudy Potion]}) {
					/casting "Cloudy Potion|Item"
				} else {
					/message \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
				}
			} else /if (${Me.Class.ShortName.Equal[BRD]}) {
				/if (${Me.AltAbility[Shauri's Sonorous Clouding]}) {
					/alt act ${Me.AltAbility[Shauri's Sonorous Clouding]}
					/delay 5
					/squelch /removelev
				} else /if (${FindItemCount[Cloudy Potion]}) {
					/casting "Cloudy Potion|Item"
				} else {
					/message \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
				}
			} else /if (${Me.Class.ShortName.Equal[MAG]} || ${Me.Class.ShortName.Equal[WIZ]} || ${Me.Class.ShortName.Equal[ENC]}) {
				/if (${Me.AltAbility[Perfected Invisibility]}) {
					/alt act ${Me.AltAbility[Perfected Invisibility]}
				} else /if (${Me.AltAbility[Group Perfected Invisibility]}) {
					/alt act ${Me.AltAbility[Group Perfected Invisibility]}
				} else /if (${FindItemCount[Cloudy Potion]}) {
					/casting "Cloudy Potion|Item"
				} else {
					/message \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
				}
			} else /if (${Me.Class.ShortName.Equal[SHM]}) {
				/if (${Me.AltAbility[Spirit Walk]}) {
					/alt act ${Me.AltAbility[Spirit Walk]}
				} else /if (${FindItemCount[Cloudy Potion]}) {
					/casting "Cloudy Potion|Item"
				} else {
					/message \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
				}
			} else /if (${Me.Class.ShortName.Equal[BST]}) {
				/if (${Me.AltAbility[Natural Invisibility]}) {
					/alt act ${Me.AltAbility[Natural Invisibility]}
				} else /if (${FindItemCount[Cloudy Potion]}) {
					/casting "Cloudy Potion|Item"
				} else {
					/message \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
				}
			} else /if (${Me.Class.ShortName.Equal[RNG]} || ${Me.Class.ShortName.Equal[DRU]}) {
				/if (${Me.AltAbility[Camouflage]}) {
					/alt act ${Me.AltAbility[Camouflage]}
				} else /if (${FindItemCount[Cloudy Potion]}) {
					/casting "Cloudy Potion|Item"
				} else {
					/message \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
				}
			} else /if (${Me.Class.ShortName.Equal[ROG]}) {
				/if (${Me.AbilityReady[Hide]}) {
				/doability "Hide"
				/delay 1s
				}
				/if (${Me.AbilityReady[Sneak]}) {
				/doability "Sneak"
				/delay 1s
				} else /if (${FindItemCount[Cloudy Potion]}) {
					/casting "Cloudy Potion|Item"
				} else {
					/message \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
				}
			} else /if (${FindItemCount[Cloudy Potion]}) {
				/casting "Cloudy Potion|Item"
			}
			/delay 3s ${Me.Invis}
	}
	|----------------------- IF ME !INVIS
	
	/if (!${Me.Invis}) /goto :CheckInvisNow
	
	/if (${Debugging}) /echo Sub CheckInvis Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: DoGrpInvisByClass
| --------------------------------------------------------------------------------------------
Sub DoGrpInvisByClass(string InvisClassShortName, String GrpInvisAltAbilityID)
	/if (${Debugging}) /echo Sub DoGrpInvisByClass Entry
	
	/declare x 					int 	local	0

	|/echo Checking for class (${InvisClassShortName}) in group.
	|/echo If Found, use ability (${GrpInvisAltAbilityID}).
			
	|-----------------------------
	/for x 1 to ${Group.Members}
		|/echo Checking for class (${InvisClassShortName}): (${Group.Member[${x}].CleanName}) - ${Group.Member[${x}].Class.ShortName.Equal[${InvisClassShortName}]} - to use ability: (${GrpInvisAltAbilityID})
		/if (${Group.Member[${x}].Class.ShortName.Equal[${InvisClassShortName}]}) {
			/message \ay[\am${Group.Member[${x}].CleanName}\ay] is a [\at${InvisClassShortName}\ay], attempting to making them cast invis (\agAlt Ability \ay[\am${GrpInvisAltAbilityID}\ay]) !
			|------------------------			
			/if ((${GrpInvisAltAbilityID}==231) && (${Group.Member[1].Level}<91)) {
				/message \ay[\am${Group.Member[${x}].CleanName}\ay] is a [\at${InvisClassShortName}\ay], but can \arNOT\ay use (\agAlt Ability \ay[\am${GrpInvisAltAbilityID}\ay]) yet due to their level !
			} else {
				/squelch /e3bct ${Group.Member[${x}].CleanName} /target clear
				/delay 1s
				/squelch /e3bct ${Group.Member[${x}].CleanName} /alt act ${GrpInvisAltAbilityID}
			}						
			/delay 3s ${Me.Invis}			
			/if (${Me.Invis}) {
				/varset x ${Group.Members}
			}
			|------------------------
		} else {
			|/echo \ay[\am${Group.Member[${x}].CleanName}\ay] is NOT a [\at${InvisClassShortName}\ay].
		}
	/next x
	|-----------------------------

	/if (${Debugging}) /echo Sub DoGrpInvisByClass Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckPlugin
| --------------------------------------------------------------------------------------------
  Sub CheckPlugin(string pluginname)
  /if (${Debugging}) /echo Sub CheckPlugin Entry
  	
	|------------
	/if (!${Bool[${Plugin[${pluginname}]}]} && !${pluginname.Equal[E3BCS]}) {
		/message \ag${pluginname}\ax \arNOT\ax detected! This macro requires it! Loading ...
		/squelch /plugin ${pluginname}
		/if (!${Bool[${Plugin[${pluginname}]}]}) {
			/message \ag${pluginname}\ax \arSTILL NOT\ax detected! This macro requires it! EXITING ...
			/endmacro
		} else {
		    /message \ag${pluginname}\ax \atNOW\ax detected !
		}
	} else {
		/message \ag${pluginname}\ax detected!
	}
	|------------
		
	|------------
	|-- Test if we are using E3.
	/if (${pluginname.Equal[E3BCS]}) {
		/if (!${MQ2Mono.Query[e3,InCombat].Equal[NULL]}) {
			/varset UsingE3BC TRUE
			/message \agYou \ayARE connected\ax using \atE3's\ax native \atE3BCS\ax communication system !		
		} else {
			/varset UsingE3BC FALSE
			/message \agYou \arare NOT connected\ax using \atE3's\ax native \atE3BCS\ax communication system !		
		}
	}
	|------------	

	|------------
	|-- Test if we are using MQ2DanNet.
	/if (${pluginname.Equal[MQ2DanNet]}) {
		/if (${Bool[${Plugin[${pluginname}]}]} && ${pluginname.Equal[MQ2DanNet]}) {
			/varset UsingMQ2DanNet TRUE
			/message \agYou \ayARE connected\ax using \atMQ2DanNet\ax communication system !
		} else {
			/varset UsingMQ2DanNet FALSE
			/message \agYou \arare NOT connected\ax using \atMQ2DanNet\ax communication system !
		}
	}
	|------------
	
	/if (${Debugging}) /echo Sub CheckPlugin Exit
  /return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckMesh  ( Called from CheckThings )
| --------------------------------------------------------------------------------------------
Sub CheckMesh
	/if (${Debugging}) /echo Sub CheckMesh Entry
	/if (!${Navigation.MeshLoaded}) {
		/nav reload
		/delay 3s ${Navigation.MeshLoaded}
		/if (!${Navigation.MeshLoaded}) {
			/message \arNo navigational mesh could be found for this zone. Make one and try again.
			/varset Endmac TRUE
		}
	}
	/if (${Debugging}) /echo Sub CheckMesh Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckINI
| --------------------------------------------------------------------------------------------
Sub CheckINI(string IniName,string Section,string Key,string TypeVar,Default)
    /if (${Debugging}) /echo (IniName:${IniName} Section:${Section} Key:${Key} TypeVar:${TypeVar})
	/if (${Debugging}) /echo Sub CheckINI Entry
	/if (!${Ini[${IniName},${Section},${Key}].Length}) {
		/ini ${IniName} ${Section} ${Key} ${Default}
	}
	/declare ${Key} ${TypeVar} outer ${Ini[${IniName},${Section},${Key}]}
	/message \atLoading \ayINI \ay[\am${IniName}\ay] \ar~ \aoKey: \ag${Key} \aoType: \ag${TypeVar} \aoINI Value: \at\ay[\am${Ini[${IniName},${Section},${Key}]}\ay]
	/if (${Debugging}) /echo Sub CheckINI Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: OpenAdventureWnd
| --------------------------------------------------------------------------------------------
Sub OpenAdventureWnd
	/if (${Debugging}) /echo Sub OpenAdventureWnd Entry
	:OpenAdvWindow
	/if (!${Window[AdventureRequestWnd].Open}) /squelch /windowstate AdventureRequestWnd open
	/delay 1s ${Window[AdventureRequestWnd].Open}
	/if (!${Window[AdventureRequestWnd].Open}) /goto :OpenAdvWindow	
	/if (${Debugging}) /echo Sub OpenAdventureWnd Exit	
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CloseAdventureWnd
| --------------------------------------------------------------------------------------------			  
Sub CloseAdventureWnd
	/if (${Debugging}) /echo Sub CloseAdventureWnd Entry
	:CloseAdvWindow
	/if (${Window[AdventureRequestWnd].Open}) /squelch /windowstate AdventureRequestWnd close
	/delay 1s !${Window[AdventureRequestWnd].Open}
	/if (${Window[AdventureRequestWnd].Open}) /goto :CloseAdvWindow	
	/e3bcaa /squelch /windowstate AdventureRequestWnd close
	/if (${Debugging}) /echo Sub CloseAdventureWnd Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: OpenAdventureStatsWnd
| --------------------------------------------------------------------------------------------
Sub OpenAdventureStatsWnd
	|---------------------------------------------------------------------------------------------------
	|NOTE: Must use this method, a direct call to open AdventureRequestWnd via /windowstate won't work !
	|---------------------------------------------------------------------------------------------------
	/if (${Debugging}) /echo Sub OpenAdventureStatsWnd Entry
	:OpenAdvStatsWindow
	/if (!${Window[AdventureRequestWnd].Open}) /squelch /windowstate AdventureRequestWnd open
	/delay 1s ${Window[AdventureRequestWnd].Open}	
	/delay 5
	/if (${Window[AdventureRequestWnd].Open}) /squelch /notify AdventureRequestWnd AdvRqst_ViewStatsButton leftmouseup
	/delay 1s ${Window[AdventureStatsWnd].Open}
	/delay 5
	/if (!${Window[AdventureStatsWnd].Open}) /goto :OpenAdvStatsWindow
	
	/if (${Debugging}) /echo Sub OpenAdventureStatsWnd Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CloseAdventureStatsWnd
| --------------------------------------------------------------------------------------------			  
Sub CloseAdventureStatsWnd
	/if (${Debugging}) /echo Sub CloseAdventureStatsWnd Entry
	:CloseAdvStatsWindow
	/squelch /windowstate AdventureStatsWnd close
	/delay 1s !${Window[AdventureStatsWnd].Open}
	/if (${Window[AdventureStatsWnd].Open}) /goto :CloseAdvStatsWindow	
	:CloseAdvWindow2
	/if (${Window[AdventureRequestWnd].Open}) /squelch /windowstate AdventureRequestWnd close
	/delay 1s !${Window[AdventureRequestWnd].Open}
	/if (${Window[AdventureRequestWnd].Open}) /goto :CloseAdvWindow2	
	
	/if (${Debugging}) /echo Sub CloseAdventureStatsWnd Exit	
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GMCheck
| --------------------------------------------------------------------------------------------
Sub GMCheck
/if (${Debugging}) /echo Sub GMCheck Entry
/if (${Spawn[gm].ID} && ${AFKGM}) {
				/message \ar WARNING GM nearby!
				/if (${UseBeep}) /beep
				|------------------------------------------------
				|--- DON't Call Gmmode, just call FinishAdventure
				|/call GMMode
				/call FinishAdventure
				|------------------------------------------------
				}
/if (${Debugging}) /echo Sub GMCheck Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GMMode
| --------------------------------------------------------------------------------------------
Sub GMMode
/if (${Debugging}) /echo Sub GMMode Entry
		/if (${UseBeep}) /beep
		/popcustom 13 5 Warning! GMMode: GM is Present!
		/message ==================================================================
		/message \ar***** GM IN ZONE, PAUSING MACRO *****\ax
		/message ==================================================================
		/mqp

/if (${Debugging}) /echo Sub GMMode Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GroupDeathChk
| --------------------------------------------------------------------------------------------
Sub GroupDeathChk
	/if (${Debugging}) /echo Sub GroupDeathChk Entry
	|--- If ImDead
	/if (${Me.State.Equal[DEAD]}) {
		/message \arYOU~ have died! Waiting for YOU to get off your face.
		|----------
		/while (${Me.State.Equal[DEAD]} ) {
			/call GMCheck
			/beep
			/beep
			/beep
			/delay 30
		}
		|----------
	}
	|--- If ImDead
	/if (${Me.XTarget[1].ID}) /return
	|--- If Group --
	/if (${Group}) {
		/declare i int local
		|----------------------------------
		/for i 1 to ${Group}
			| -- If GroupMember IsDead
			/if (${Group.Member[${i}].State.Equal[DEAD]} ) {
				/message ${Group.Member[${i}].Name} has died. Waiting for them to get off their face.
				|------   If No Target ID
				/if (!${Me.XTarget[1].ID}) {
					|----------------------------------
					/while (${Group.Member[${i}].State.Equal[DEAD]} && !${Me.XTarget[1].ID}) {
						/call GMCheck
						/if ((${Me.Standing}) && (!${Me.Casting.ID}) && (!${Me.Mount.ID})) /sit
						/beep
						/delay 30
					}
					/squelch /e3bcg /stand
				}
				|------   If No Target ID
			}
			| -- If GroupMember IsDead
		/next i
		|----------------------------------
	}
	|--- If Group --

	/if (${Debugging}) /echo Sub GroupDeathChk Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GroupManaChk
| --------------------------------------------------------------------------------------------
Sub GroupManaChk
	/if (${Debugging}) /echo Sub GroupManaChk Entry
	/if (${Me.XTarget[1].ID}) /return

	|------------------- If NoCombat
	/if (!${Me.Combat}) {
		|---
		|--- If Me LowMana
		/if ((${Me.PctMana} < ${MedAt} && !${Me.State.Equal[DEAD]} && !${Select[${Me.Class.ShortName},WAR,BER,ROG,MNK,BRD]}) || (${BardMed} && ${Me.PctMana} < ${MedAt} && !${Me.State.Equal[DEAD]} && ${Me.Class.ShortName.Equal[BRD]})) {
			/message \arYOU are low on mana!
			/call Group2Me
			|------   If No Target ID
			/if (!${Me.XTarget[1].ID}) {
				|--------------------------------------
				/while ((${Me.PctMana} < ${MedTill} && !${Me.XTarget[1].ID} && !${Me.State.Equal[DEAD]} && !${Select[${Me.Class.ShortName},WAR,BER,ROG,MNK,BRD]}) || (${BardMed} && ${Me.PctMana} < ${MedTill} && !${Me.XTarget[1].ID} && !${Me.State.Equal[DEAD]} && ${Me.Class.ShortName.Equal[BRD]})) {
					/message \agYour \am[\atMana\am]\ag is currently at \am[\at${Me.PctMana}\am]\ag%, medding to \am[\at${MedTill}\am]\ag%.
					/call GMCheck
					/if (${Me.Standing} && !${Me.Casting.ID} && !${Me.Mount.ID} && !${Navigation.Active}) /sit
					/delay 6s
				}
                /squelch /e3bcg /stand
			}
			|------   If No Target ID
		}
		|--- If Me LowMana
		|--- If Group --
		/if (${Group}) {
			/declare i int local
			|--------------------------------------
			/for i 1 to ${Group}
				|------   If Valid GroupMemeber
				/if ((${Group.Member[${i}].PctMana} < ${MedAt} && ${Group.Member[${i}].Class.CanCast} && !${Group.Member[${i}].State.Equal[DEAD]} && !${Select[${Group.Member[${i}].Class.ShortName},BRD,WAR,MNK,BER,ROG]}) || (${BardMed} && (${Group.Member[${i}].PctMana} < ${MedAt}) && !${Group.Member[${i}].State.Equal[DEAD]} && ${Group.Member[${i}].Class.ShortName.Equal[BRD]})) {
					/message \ar${Group.Member[${i}].Name} is low on mana!
					/call Group2Me
					|--------------
					| Make Them Sit
					|--------------
					/squelch /e3bct ${Group.Member[${i}].CleanName} /sit
					|----
					/call Refresh
					|------   If No Target ID
					/if (!${Me.XTarget[1].ID}) {
						|--------------------------------------
						/while ((${Group.Member[${i}].PctMana} < ${MedTill} && ${Group.Member[${i}].Class.CanCast} && !${Me.XTarget[1].ID} && !${Group.Member[${i}].State.Equal[DEAD]} && !${Select[${Group.Member[${i}].Class.ShortName},BRD,WAR,MNK,BER,ROG]}) || (${BardMed} && ${Group.Member[${i}].PctMana} < ${MedTill} && !${Me.XTarget[1].ID} && !${Group.Member[${i}].State.Equal[DEAD]} && ${Group.Member[${i}].Class.ShortName.Equal[BRD]})) {
							/message \ag${Group.Member[${i}].CleanName}'s \am[\atMana\am]\ag is currently at \am[\at${Group.Member[${i}].PctMana}\am]\ag%, medding to \am[\at${MedTill}\am]\ag%.
							/call GMCheck
							/if (${Me.Standing} && !${Me.Casting.ID} && !${Me.Mount.ID} && !${Navigation.Active}) /sit
							/delay 3s
							|----------
							/if (${Group.Member[${i}].Standing}) {
								/delay 6s
								/squelch /e3bct ${Group.Member[${i}].CleanName} /sit
							}
							|----------
						}
						/squelch /e3bcg /stand
					}
					|------   If No Target ID
				}
				|------   If Valid GroupMemeber
			/next i
			|--------------------------------------
		}
		|--- If Group --
	}
	|------------------- If NoCombat

	/if (${Debugging}) /echo Sub GroupManaChk Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GroupEndChk
| --------------------------------------------------------------------------------------------
Sub GroupEndChk
	/if (${Debugging}) /echo Sub GroupEndChk Entry
	/if (${Me.XTarget[1].ID}) /return

	|------------------- If NoCombat
	/if (!${Me.Combat}) {
		|---
		|--- If Me LowEnd
		/if ((${Me.PctEndurance} < ${MedEndAt} && !${Me.State.Equal[DEAD]} && ${Me.Class.ShortName.NotEqual[BRD]}) || (${BardMed} && ${Me.PctEndurance} < ${MedEndAt} && !${Me.State.Equal[DEAD]} && ${Me.Class.ShortName.Equal[BRD]})) {
			/message \arYOU are low on Endurance!
			/call Group2Me
			|------   If No Target ID
			/if (!${Me.XTarget[1].ID}) {
				|--------------------------------------
				/while ((${Me.PctEndurance} < ${MedEndTill} && !${Me.XTarget[1].ID} && !${Me.State.Equal[DEAD]} && ${Me.Class.ShortName.NotEqual[BRD]}) || (${BardMed} && ${Me.PctEndurance} < ${MedEndAt} && !${Me.State.Equal[DEAD]} && ${Me.Class.ShortName.Equal[BRD]})) {
					/message \agYour \am[\atEndurance\am]\ag is currently at \am[\at${Me.PctEndurance}\am]\ag%, medding to \am[\at${MedEndTill}\am]\ag%.
					/call GMCheck
					/if (${Me.Standing} && !${Me.Casting.ID} && !${Me.Mount.ID} && !${Navigation.Active}) /sit
					/delay 6s
				}
                /squelch /e3bcg /stand
			}
			|------   If No Target ID
		}
		|--- If Me LowEnd
		|--- If Group --
		/if (${Group}) {
			/declare i int local
			|--------------------------------------
			/for i 1 to ${Group}
				|------   If Valid GroupMemeber
				/if (${Group.Member[${i}].ID}) {
					|------   If GroupMember LowEnd
					/if ((${Group.Member[${i}].PctEndurance} < ${MedEndAt} && !${Group.Member[${i}].State.Equal[DEAD]} && ${Group.Member[${i}].Class.ShortName.NotEqual[BRD]}) || (${BardMed} && ${Group.Member[${i}].PctEndurance} < ${MedEndAt} && !${Group.Member[${i}].State.Equal[DEAD]} && ${Group.Member[${i}].Class.ShortName.Equal[BRD]})) {
						/message \ar${Group.Member[${i}].Name} is low on Endurance!
						/call Group2Me
						|--------------
						| Make Them Sit
						|--------------
						/squelch /e3bct ${Group.Member[${i}].CleanName} /sit
						/call Refresh
						|------   If No Target ID
						/if (!${Me.XTarget[1].ID}) {
							|---------------------------------------
							/while ((${Group.Member[${i}].PctEndurance} < ${MedEndTill} && !${Me.XTarget[1].ID} && !${Group.Member[${i}].State.Equal[DEAD]} && ${Group.Member[${i}].Class.ShortName.NotEqual[BRD]}) || (${BardMed} && ${Group.Member[${i}].PctEndurance} < ${MedEndTill} && !${Me.XTarget[1].ID} && !${Group.Member[${i}].State.Equal[DEAD]} && ${Group.Member[${i}].Class.ShortName.Equal[BRD]})) {
								/message \ag${Group.Member[${i}].CleanName}'s \am[\atEndurance\am]\ag is currently at \am[\at${Group.Member[${i}].PctEndurance}\am]\ag%, medding to \am[\at${MedEndTill}\am]\ag%.
								/call GMCheck
								/if (${Me.Standing} && !${Me.Casting.ID} && !${Me.Mount.ID} && !${Navigation.Active}) /sit
								/delay 3s
								|----------
								/if (${Group.Member[${i}].Standing}) {
									/delay 6s
									/squelch /e3bct ${Group.Member[${i}].CleanName} /sit
								}
								|----------
						}
						|---------------------------------------
						/squelch /e3bcg /stand
						}
						|------   If No Target ID
					}
					|------   If GroupMember LowEnd
				}
				|------   If Valid GroupMemeber
			/next i
			|--------------------------------------
		}
		|--- If Group --
	}
	|------------------- If NoCombat

	/if (${Debugging}) /echo Sub GroupEndChk Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckMerc
| --------------------------------------------------------------------------------------------
Sub CheckMerc
	/if (${Debugging}) /echo Sub CheckMerc Entry
	/if (${Mercenary.State.Equal[DEAD]} && ${UseMerc}) {
		/message Your mercenary has died. Waiting to be able to revive them. 
		:waitForMerc
		/if (${Group} && ${Window[MMGW_ManageWnd].Child[MMGW_SuspendButton].Tooltip.Equal[Revive your current mercenary.]} && ${Window[MMGW_ManageWnd].Child[MMGW_SuspendButton].Enabled}) /notify MMGW_ManageWnd MMGW_SuspendButton leftmouseup
		/if (${Mercenary.State.Equal[DEAD]} && !${Me.XTarget[1].ID}) /goto :waitForMerc
		
	}
	/varset MercClass ${Mercenary.Class}
	/if (${Mercenary.State.Equal[ACTIVE]} && ${Mercenary.Stance.NotEqual[Balanced]} && ${MercClass.Equal[Cleric]} && ${UseMerc}) {
			/stance Balanced
			/message \aySetting Mercenary to \at[\agBalanced\at]
	}
	/if (${Mercenary.State.Equal[ACTIVE]} && ${Mercenary.Stance.NotEqual[Assist]} && ${MercClass.Equal[Warrior]} && ${UseMerc}) {
			/stance Assist
			/message \aySetting Mercenary to \at[\agAssist\at]
	}
	/if (${Mercenary.State.Equal[ACTIVE]} && ${Mercenary.Stance.NotEqual[Assist]} && ${MercClass.Equal[Rogue]} && ${UseMerc}) {
			/stance Assist
			/message \aySetting Mercenary to \at[\agAssist\at]
	}
	/if (${Mercenary.State.Equal[ACTIVE]} && ${Mercenary.Stance.NotEqual[Assist]} && ${MercClass.Equal[Wizard]} && ${UseMerc}) {
			/stance Assist
			/message \aySetting Mercenary to \at[\agAssist\at]
	}
	/if (${Debugging}) /echo Sub CheckMerc Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: NavToLoc -- [NO Combat and Agro Aware movement]
| --------------------------------------------------------------------------------------------
Sub NavToLoc(int Y,int X,int Z)
	/if (${Debugging}) /echo Entering Sub NavToLoc for ${Y} ${X} ${Z} at Line: ${Macro.CurLine}
	/varset GroupWaitTimer 0
	/message \at -- NavToLoc \ay[\amNo Combat & Agro aware movement\ay] \atto \ay[\am${Y} ${X} ${Z}\ay]\at.
	|-------------------------------------------------------------------------------
	/while (${Math.Distance[${Me.Y}, ${Me.X}, ${Me.Z}: ${Y}, ${X}, ${Z}]} > 30) {
		/if (${Navigation.Active}) {
			/if (${CheckBots}) /call GroupDeathChk
			/if (${CheckBots}) /call GroupManaChk
			/if (${CheckBots}) /call GroupEndChk
			/call GMCheck
			/if (${Me.XTarget[1].ID}) {
				/if (${Navigation.Active}) /nav stop
				/if (${Debugging}) /echo CALL DoSingleMob NavToLoc
				/call DoSingleMob
			} else {
				/if (${CheckBots}) /call GroupDeathChk
				/if (${CheckBots}) /call GroupManaChk
				/if (${CheckBots}) /call GroupEndChk
				/call GMCheck
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/delay 10
		} else {
			/if (${Me.XTarget[1].ID}) {
				/if (${Navigation.Active}) /nav stop
				/if (${Debugging}) /echo CALL FARM STUFF NavToLoc II
				/call DoSingleMob
			} else {
				/if (${CheckBots}) /call GroupDeathChk
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/if (!${Me.Combat} && !${Me.XTarget[1].ID}) /call Group2Me
			/if (!${Me.Moving}) /squelch /e3bcgza /nav loc ${Y} ${X} ${Z}
			/delay 5 ${Me.Moving}
			/delay 5 ${Navigation.Active}
		}
	}
	|-------------------------------------------------------------------------------
	/delay 2s
	/if (${Navigation.Active}) /nav stop
	/if (${Debugging}) /echo Sub NavToLoc Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: NavToLoc2 -- [Combat and Agro Aware movement]
| --------------------------------------------------------------------------------------------
Sub NavToLoc2(int Y,int X,int Z)
	/if (${Debugging}) /echo Entering Sub NavToLoc2 for ${Y} ${X} ${Z} at Line: ${Macro.CurLine}
	/varset GroupWaitTimer 0
	/message \at -- NavToLoc2 \ay[\amCombat & Agro aware movement\ay] \atto \ay[\am${Y} ${X} ${Z}\ay]\at.
	/while (${Math.Distance[${Me.Y}, ${Me.X}, ${Me.Z}: ${Y}, ${X}, ${Z}]} > 20) {
		/if (${Navigation.Active}) {
			/if (${Debugging}) /echo WaitNav Moving ELSE
			/if (${CheckBots}) /call GroupDeathChk
			/if (${CheckBots}) /call GroupManaChk
			/if (${CheckBots}) /call GroupEndChk
			/call GMCheck
			/if (${Me.XTarget[1].ID}) {
				/popcustom 13 5 ---> GOT AGGRO ON ROUTE <---
				/if (${Navigation.Active}) /nav stop
				/if (${Debugging}) /echo CALL DoSinglePull NavToLoc						
				/target ${Me.XTarget[1].ID}
				/if (${Spawn[id ${Target.ID}].Distance} > 30) /squelch /nav id ${Target.ID}
				/if (${Me.XTarget[1].ID} && ${Spawn[id ${Target.ID}].Distance} < 30) {
					|------  CALL GROUP TO ME To FIGHT
					/call Group2Me
					|------  CALL GROUP TO ME To FIGHT					
					/if (${Target.ID}) /face
					/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
					/squelch /attack on
					/call DoClearTargets
					/call CheckForCorpses
					/call CheckMissionSuccess
					/doevents
					/if (${UseClickDamage}) /call Clickies_Damage
				}
			} else {
				/if (${Debugging}) /echo WaitNav Moving ELSE
				/if (${CheckBots}) /call GroupDeathChk
				/if (${CheckBots}) /call GroupManaChk
				/if (${CheckBots}) /call GroupEndChk
				/call GMCheck
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/delay 10
		} else {
			/if (${Me.XTarget[1].ID}) {
				/popcustom 13 5 ---> GOT AGGRO ON ROUTE <---
				/if (${Navigation.Active}) /nav stop
				/if (${Debugging}) /echo CALL FARM STUFF NavToLoc II				
				/target ${Me.XTarget[1].ID}
				/if (${Spawn[id ${Target.ID}].Distance} > 30) /squelch /nav id ${Target.ID}
				/if (${Me.XTarget[1].ID} && ${Spawn[id ${Target.ID}].Distance} < 30) {
				|------  CALL GROUP TO ME To FIGHT
				/call Group2Me
				|------  CALL GROUP TO ME To FIGHT					
				/if (${Target.ID}) /face
				/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
				/squelch /attack on
				/call DoClearTargets
				/call CheckForCorpses
				/call CheckMissionSuccess
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}
			} else {
				/if (${CheckBots}) /call GroupDeathChk
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/if (!${Me.Moving} && !${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /e3bcgza /nav loc ${Y} ${X} ${Z}
			/delay 5 ${Me.Moving}
			/delay 5 ${Navigation.Active}
		}
	}
	/delay 2s
	/if (${Navigation.Active}) /nav stop
	/if (${Debugging}) /echo Sub NavToLoc2 Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: WaitNav
| --------------------------------------------------------------------------------------------
Sub WaitNav(NavTargetID)
	/if (${Debugging}) /echo \agEntering Sub WaitNav for ${Spawn[id ${NavTargetID}].Y} ${Spawn[id ${NavTargetID}].X} ${Spawn[id ${NavTargetID}].Z} at Line: ${Macro.CurLine}
	/message \at -- WaitNav \ay[\amNo Combat & Agro aware STAGGERED movement\ay] \atto mob id:\ay[\am${NavTargetID}\ay]\at.
	/if (!${Spawn[id ${NavTargetID}].ID}) {
		/delay 5s
		/return
	}
	/while (${Spawn[id ${NavTargetID}].Distance} > 30 || !${Spawn[${myTargetID}].LineOfSight}) {
		/if (!${Spawn[id ${NavTargetID}].ID}) {
			/delay 5s
			/return
		}
		/if (${Spawn[id ${NavTargetID}].Distance} < 30) {
			/nav stop
		}
		/if (${Spawn[id ${NavTargetID}].ID}) {
			/call SetLoc
			/call CheckStuck
			/call GMCheck
			/if (${Me.XTarget[1].ID}) {
				/if (${Navigation.Active}) /nav stop
				/varset NavTargetID ${Me.XTarget[1].ID}
				/if (${Debugging}) /echo CALL FARM STUFF WaitNAV
				/call DoSingleMob
			} else {
				/if (${Debugging}) /echo \ayWaitNav Moving
				/if (${CheckBots}) /call GroupDeathChk
				/if (${CheckBots}) /call GroupManaChk
				/if (${CheckBots}) /call GroupEndChk
				/call GMCheck
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/if (!${courseCorrection}) {
				|------  ALL GO TO TARGET - staggered
				/nav id ${NavTargetID}
				/delay 5
				/squelch /e3bca /nav id ${NavTargetID}
				|------  ALL GO TO TARGET - staggered
				/varset courseCorrection ${courseCorrection.OriginalValue}
			}
			|----------------------------------
			| Should group come to me on pulls. 
			|----------------------------------
			/if (${GroupNavToMe}) {
                /call Group2Me
            }
			|----------------------------------
			/delay 10
		} else {
			/if (${Me.XTarget[1].ID}) {
				/if (${Navigation.Active}) /nav stop
				/e3bcgza /target id ${Me.XTarget[1].ID}
				/varset NavTargetID ${Me.XTarget[1].ID}
				/if (${Debugging}) /echo CALL DoSingleMob WaitNav II
				/call DoSingleMob
			} else {
				/varcalc BackUpTimer (${BackUpTimer})+1
				/if (${BackUpTimer}>7) {
					/message \ayHaving trouble getting to a target.. Attempting to get back on mesh.
					/if (${Debugging}) /echo Setting BackUpTimer Plus 1
					/call BackUp
					/varset BackUpTimer 0
					/varset NavTargetID 0
					/if (${Me.XTarget[1].ID}) {
						/varset NavTargetID ${Me.XTarget[1].ID}
					}
				}
				/if (${Debugging}) /echo WaitNav Moving ELSE
				/if (${CheckBots}) /call GroupDeathChk
				/if (${CheckBots}) /call GroupManaChk
				/if (${CheckBots}) /call GroupEndChk
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/squelch /nav id ${NavTargetID}
		}
	}
	/if (${Navigation.Active}) /nav stop
	:target
	/target id ${NavTargetID}
	/delay 2s ${Target.CleanName.Equal[${Spawn[id ${NavTargetID}].CleanName}]}
	/if (!${Target.CleanName.Equal[${Spawn[id ${NavTargetID}].CleanName}]} && ${Spawn[id ${NavTargetID}].ID} && !${Me.XTarget[1].ID}) {
		/goto :target
	}
	/if (${Debugging}) /echo Sub WaitNav Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
|SUB: AutoSell_Loot
| --------------------------------------------------------------------------------------------
  Sub AutoSell_Loot
  /if (${Debugging}) /echo Sub AutoSell_Loot Entry

  	|--------------------------
	/message \am<***> Sending the rest of my group to Magus as I sell <***>
  	/squelch /e3bca /tar Magus Alaria
	/delay 5
	/squelch /e3bca /nav target
	/delay 5
	|--------------------------

	/declare MerchName	string	local Merabo

	/message \aw<\ar$\ao$\ay$\ag$\at$\au$\am$\ap$\aw> \agAttempting to locate a \ay[\at${MerchName}\ay]\ag to \ay[\atAutoSell\ay]\ag ! \aw<\ap$\am$\au$\at$\ag$\ay$\ao$\ar$\aw>
	/target clear
	/delay 2s !${Target.ID}

	/squelch /target ${MerchName}
	/delay 2s ${Target.ID}

	|-------------------------------------
	/if (${Target.ID}) {
		/squelch /nav id ${Target.ID}
		/delay 5
		/while (${Navigation.Active}) {
			/call SetLoc
			/call CheckStuck
			/delay 5
		}
	}
	/delay 5
	|-------------------------------------

	|------------------
	/call ReclaimAltDC
	|------------------

	|-------------------------------------
	/if (${Target.ID} && ${Target.Distance}<=20) {
		/nomodkey /click right target
		/delay 5s ${Window[MerchantWnd].Open}
		/message \ay Attempting to \amAutoSell\ax now.
		/delay 1s
		/call OpenPacks
		/delay 1s
		/autosell
		|-----------------
		/while (${Window[MerchantWnd].Open}) {
			/delay 5
		}
		|-----------------
		/call ClosePacks
		/delay 1s
	}
	|-------------------------------------

	/message \aw<\ar$\ao$\ay$\ag$\at$\au$\am$\ap$\aw> \agDone Selling! \ag \aw<\ap$\am$\au$\at$\ag$\ay$\ao$\ar$\aw>

	/if (${Debugging}) /echo Sub AutoSell_Loot Exit
  /return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
|SUB: ReclaimAltDC
| --------------------------------------------------------------------------------------------
Sub ReclaimAltDC
 /if (${Debugging}) /echo Sub ReclaimAltDC Entry

	/varset CurrentDC ${FindItemCount[=Diamond Coin]}
	/varset CurrentDCAC ${Me.AltCurrency[20]}
	/message \ayDiamond Coin: Alternate Currency=(\at${CurrentDCAC}\ay) | Inventory=(\at${CurrentDC}\ax)

	|-----------------------------------------------
	/if (${CurrentDC}>0) {
		; --- If I have DC in inventory, RECLAIM it to Alternate Currency !!!
		/message \ag$$$\ay I have [\atDiamond Coin\ay]  to reclaim!\ax

		; Open the Inventory Window if it is closed
		|----------------------------------------------
		/if (!${Window[InventoryWindow].Open}) /call OpenInvWindow
		|----------------------------------------------

		; Select Alt Currency Tab
		/if (${Debugging}) /echo Selecting Alt Currency Tab
		/if (!${Window[InventoryWindow].Child[IW_AltCurrPage].Open})  /notify InventoryWindow IW_Subwindows tabselect 5
		/delay 5

		; Select Diamond Coin off the Alternate Currecy tab in Inventory window ..  YOU NEED TO OPEN INVENTORY WINDOW FOR THIS !
		/if (${Debugging}) /echo Selecting Diamond Coins
		/notify InventoryWindow IW_AltCurr_PointList listselect 2
		/delay 5

		; Click the RECLAIM BUTTON after selecting Diamond Coin previously
		/nomodkey /notify InventoryWindow AltCurr_ReclaimButton LeftMouseUp
		/delay 5
	} else {
	    ; --- If I have NO DC in inventory to RECLAIM
		/message \ag$$$\ay I have \arNO\ay [\atDiamond Coin\ay] to reclaim!\ax
	}
	|-----------------------------------------------
	; Update the DC and Alternate DC Currency ammount.
	/varset CurrentDC ${FindItemCount[=Diamond Coin]}
	/varset CurrentDCAC ${Me.AltCurrency[20]}
	/message \ayDiamond Coin: Alternate Currency=(\at${CurrentDCAC}\ay) | Inventory=(\at${CurrentDC}\ax)
	; Close the Inventory Window if it is open
	|----------------------------------------------
	/if (${Window[InventoryWindow].Open}) /call CloseInvWindow
	|----------------------------------------------

	/if (${CurrentDC}==0) /message \ag$$$ \ayAll available DC was converted to Alternate Currency !

/if (${Debugging}) /echo Sub ReclaimAltDC Exit

/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
|SUB: CheckForCorpses
| --------------------------------------------------------------------------------------------
  Sub CheckForCorpses
  /if (${Debugging}) /echo Sub CheckForCorpses Entry

  /call GMCheck
  /hidecorpse looted

:CheckAgain
  /message \ay- Checking for missed corpse(s).
  /squelch /target radius 100 corpse
  /delay 5 ${Target.ID}

  /if (${Target.ID} && ${Target.Type.Equal[Corpse]}) {
    /message \at+++ \ayLooks like we have a corpse to loot!\ax
    /if (${Target.ID}) /face nolook

	|----------------------------------------------
	|-----
	/if (${Navigation.PathExists[id ${Target.ID}]}) {
		/if (${Target.ID} && !${Me.Casting.ID}) /nav id ${Target.ID}
	} else {
		 /if (${Target.ID} && !${Me.Casting.ID}) /moveto id ${Target.ID} mdist 10
	}
	|-----
    |----------------------------------------------

	|-------------------------
	/call CheckCasting
	/delay 5 !${Me.Moving}
	|--------------------------------------------------------------------------------
	/if (!${Me.XTarget[1].ID} && !${Me.Casting.ID} && !${Me.Moving} && ${LootMethod.Equal[DCONLY]}) /call LootMob_DC_Only
	/if (!${Me.XTarget[1].ID} && !${Me.Casting.ID} && !${Me.Moving} && ${LootMethod.Equal[E3]}) /call LootMob_E3
	|--------------------------------------------------------------------------------

    /squelch /target clear
    /goto :CheckAgain
  } else {
    /message \ar+++ \ayNo corpse(s) found to loot.\ax
  }

	/if (${Debugging}) /echo Sub CheckForCorpses Exit
  /return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
|SUB: LootMob_E3 -- Let E3 Looting handle your corpseloot.
| --------------------------------------------------------------------------------------------
  Sub LootMob_E3
	/if (${Debugging}) /echo Sub LootMob_E3 Entry

	/if (${Target.ID}) /face nolook
	/keypress forward
	/keypress back
	/fastdrop on
	/lootn never
	/delay 5
	|---------------------------------------
	| -- Let E3 Looting System handle this !
	|---------------------------------------
	|---------------------------------------
	| -- HANDLE CONDITIONALY !
	|---------------------------------------
	/if (!${Me.XTarget[1].ID}) {
		/loot
	} else {
		/call DoClearTargets
	}
	|---------------------------------------
	| -- HANDLE CONDITIONALY !
	|---------------------------------------
	|---------------------------------------
	| -- Let E3 Looting System handle this !
	|---------------------------------------
	|--------------------------------------------
	/if (${Me.XTarget[1].ID}) /call DoClearTargets
	|--------------------------------------------
	/doevents
	|-------------------------------------------------------------------------------------
	/if (!${Me.XTarget[1].ID} && !${Me.Casting.ID} && !${Me.Moving}) /call CheckIfBagsFull
	|-------------------------------------------------------------------------------------

	/if (${Debugging}) /echo Sub LootMob_E3 Exit
  /return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
|SUB: LootMob_DC_Only: Standard coin and Diamond Coin
| --------------------------------------------------------------------------------------------
  Sub LootMob_DC_Only
    /if (${Debugging}) /echo Sub LootMob_DC_Only Entry
	
	/declare x  		 			int inner	1
	/declare LootSlot    			int inner	0
    /declare LootCheck  			int inner	0
    /declare LootTotal   			int inner	0
	/declare CursorItemValueInPlat	int inner	0

	/if (${Target.ID}) /face nolook
    /keypress forward
    /keypress back
    /fastdrop on
    /lootn never
    /delay 1s

	|---------------------------------------
	| -- HANDLE CONDITIONALY !
	|---------------------------------------
	/if (!${Me.XTarget[1].ID}) {
		/loot
	} else {
		/call DoClearTargets
	}
	|---------------------------------------
	| -- HANDLE CONDITIONALY !
	|---------------------------------------

    /delay 2s ${Window[LootWnd].Open}
    /doevents

	|--------------------------------------
	/if (!${Corpse.Items}) {
		/message \ar- NO LOOT! - Cheap Bastard !
    } else {
		/delay 1s ${Corpse.Items}!=NULL
		/varset LootTotal ${Corpse.Items}
		/message \ay++ Corpse has (\at${LootTotal}\ay) item(s) on it to loot.
		|---------------------------------------
		/for LootSlot 1 to ${LootTotal}
			/message \ay-- Grabbing corpse item (\am${LootSlot}\ax) of (\am${LootTotal}\ax).
			/nomodkey /shift /itemnotify Loot${LootSlot} leftmouseup
			/delay 1s ${Cursor.ID}
			/if (${Window[QuantityWnd].Open}) /notify QuantityWnd QTYW_Accept_Button leftmouseup
			/delay 1s

			|----------------------------------------------------------------------------------------------
			/varset CursorItemValueInPlat ${Math.Calc[${FindItem[=${Cursor.Name}].Value}/1000]}
			|----------------------------------------------------------------------------------------------
			
			|/echo (${Cursor.Name}) -- CursorItemValueInPlat=(${CursorItemValueInPlat}) | {MinItemValue})=${MinItemValue})

			|--------------------------------------------------------
			|---- ALL VALUABLE STACKABLE LOOT THAT DROPS IN THIS ZONE
			|--------------------------------------------------------	
			/if (${Cursor.ID}) {			
				/if (${Cursor.Name.Equal[Diamond Coin]}) {
					/message \at+\ax \agKeeping a\ax \ay(\atDiamond Coin\ay) \ag worth \ay(\at${CursorItemValueInPlat}\ay)\ag platinum ... WOOT!\ax
					/autoinventory 
					/delay 5 !${Cursor.ID}
				} else /if (${CursorItemValueInPlat}>${MinItemValue}) {
					/message \at+\ax \agKeeping a\ax \ay(\at${Cursor.Name}\ay) \ag worth \ay(\at${CursorItemValueInPlat}\ay)\ag platinum ... WOOT!\ax
					/autoinventory 
					/delay 1s !${Cursor.ID}
				}
			}
			|--------------------------------------------------------

			|--------------------------------------------------------
			|---- DESTROY ANYTHING REMAINING
			|--------------------------------------------------------
			/if (${Cursor.ID}) {				
				/message \ar-\ax \arDestroying a\ax \ay(\at${Cursor.Name}\ay)\ar, that crap is woth less than \ay(\at${MinItemValue}\ay)\ar plat!\ax --(${CursorItemValueInPlat})--
				/destroy
				/delay 1s !${Cursor.ID}
			}
			|--------------------------------------------------------
		/doevents
		|--------------------------------------------
		/if (${Me.XTarget[1].ID}) /call DoClearTargets
		|--------------------------------------------
		/next LootSlot
		|---------------------------------------
    }
    |--------------------------------------

  /notify LootWnd DoneButton leftmouseup
  /delay 2s !${Window[LootWnd].Open}
  |--------------------------------------------
  /if (${Me.XTarget[1].ID}) /call DoClearTargets
  |--------------------------------------------
  /doevents
  |-------------------------------------------------------------------------------------
  /if (!${Me.XTarget[1].ID} && !${Me.Casting.ID} && !${Me.Moving}) /call CheckIfBagsFull
  |-------------------------------------------------------------------------------------

  /if (${Debugging}) /echo Sub LootMob_DC_Only Exit
  /return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
|SUB: CheckIfBagsFull
| --------------------------------------------------------------------------------------------
  Sub CheckIfBagsFull
  /if (${Debugging}) /echo Sub CheckIfBagsFull Entry

  |--------------------------------------------
  /if (${BagsAreFull}) {
		|--------------------------------------------
		/if (${Me.AltAbilityReady[Summon Resupply Agent]}) {
			/message ==================================================================
			/message \ar +++ Your bags are full summoning a \ay[\atResupply Agent\ay]\ar to AutoSell.\ax
			/message ==================================================================
			/alt act ${Me.AltAbility[Summon Resupply Agent].ID}
			/delay 2s
			/call AutoSell_Loot_SupplyAgent
			/delay 1s
		} else {
			message ==================================================================
			/message \ar +++ Your bags are full and you can not summon a \ay[\atResupply Agent\ay]\ar to AutoSell.\ax
			/message \ar --- DISABLING ${MacroName} LOOTING, YOU WILL NOT LOOT CORPSES !
			/message ==================================================================
			/squelch /lootoff
		}
		|--------------------------------------------
		/varset BagsAreFull FALSE
		|--------------------------------------------
  }
  |--------------------------------------------

  /if (${Debugging}) /echo Sub CheckIfBagsFull Exit
  /return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
|SUB: AutoSell_Loot_SupplyAgent
| --------------------------------------------------------------------------------------------
  Sub AutoSell_Loot_SupplyAgent
  /if (${Debugging}) /echo Sub AutoSell_Loot_SupplyAgent Entry

	/declare MerchName	string	local Merchant

	/message \aw<\ar$\ao$\ay$\ag$\at$\au$\am$\ap$\aw> \agAttempting to locate a \ay[\at${MerchName}\ay]\ag to \ay[\atAutoSell\ay]\ag ! \aw<\ap$\am$\au$\at$\ag$\ay$\ao$\ar$\aw>
	/target clear
	/delay 2s !${Target.ID}

	/squelch /target ${MerchName}
	/delay 2s ${Target.ID}

	|-------------------------------------
	/if (${Target.ID}) {
		/squelch /nav id ${Target.ID}
		/delay 5
		/while (${Navigation.Active}) {
			/call SetLoc
			/call CheckStuck
			/delay 5
		}
	}
	/delay 5
	|-------------------------------------

	|------------------
	/call ReclaimAltDC
	|------------------

	|-------------------------------------
	/if (${Target.ID} && ${Target.Distance}<=20) {
		/nomodkey /click right target
		/delay 5s ${Window[MerchantWnd].Open}
		/message \ay Attempting to \amAutoSell\ax now.
		/delay 1s
		/call OpenPacks
		/delay 1s
		/autosell
		|-----------------
		/while (${Window[MerchantWnd].Open}) {
			/delay 5
		}
		|-----------------
		/call ClosePacks
		/delay 1s
	}
	|-------------------------------------

	/message \aw<\ar$\ao$\ay$\ag$\at$\au$\am$\ap$\aw> \agDone Selling! \ag \aw<\ap$\am$\au$\at$\ag$\ay$\ao$\ar$\aw>

	/if (${Debugging}) /echo Sub AutoSell_Loot_SupplyAgent Exit
  /return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
|SUB: OpenInvWindow
| --------------------------------------------------------------------------------------------
  Sub OpenInvWindow
 /if (${Debugging}) /echo Sub OpenInvWindow Entry
	/if (!${Window[InventoryWindow].Open}) {
	:OpenInventoryWindow
		/nomodkey /keypress inventory
		/delay 5
		/if (${Window[InventoryWindow].Open}) /message Inventory Window (Open).
		/if (!${Window[InventoryWindow].Open}) /goto :OpenInventoryWindow
	}
 /if (${Debugging}) /echo Sub OpenInvWindow Exit
  /return
| --------------------------------------------------------------------------------------------		

| --------------------------------------------------------------------------------------------
|SUB: CloseInvWindow
| --------------------------------------------------------------------------------------------
  Sub CloseInvWindow
  /if (${Debugging}) /echo Sub CloseInvWindow Entry

	/if (${Window[InventoryWindow].Open}) {
	:CloseInventoryWindow
		/nomodkey /keypress inventory
		/delay 5
		/if (!${Window[InventoryWindow].Open}) /message Inventory Window (Closed).
		/if (${Window[InventoryWindow].Open}) /goto :CloseInventoryWindow
	}
	
  /if (${Debugging}) /echo Sub CloseInvWindow Exit
  /return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: OpenPacks
| --------------------------------------------------------------------------------------------
	Sub OpenPacks
	/declare bag int local 0
	/if (!${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
	/delay 3s ${Window[InventoryWindow].Open}
	/for bag 1 to 10
		/if (!${Window[Pack${bag}].Open}) /nomodkey /itemnotify pack${bag} rightmouseup
		/delay 3s ${Window[Pack${bag}].Open}
		/if (${Window[TradeskillWnd].Open}) /nomodkey /notify TradeskillWnd ExperimentButton leftmouseup
		/delay 5s !${Window[TradeskillWnd].Open}
	/next bag
	/return
|--------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: ClosePacks
| --------------------------------------------------------------------------------------------
	Sub ClosePacks
	/declare bag int local 0
	/if (!${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
	/delay 3s ${Window[InventoryWindow].Open}
	/for bag 1 to 10
		/if (${Window[Pack${bag}].Open}) /nomodkey /itemnotify pack${bag} rightmouseup
		/delay 3s !${Window[Pack${bag}].Open}
	/next bag
	/if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
	/delay 3s !${Window[InventoryWindow].Open}
  /return
|--------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: SetLoc
| --------------------------------------------------------------------------------------------
sub SetLoc
	/if (${Debugging}) /echo Sub SetLoc Entry
	/if (${StuckSpamTimerSet} || !${Navigation.Active}) /return 
	/varset OutX1 ${Me.X}
    /varset OutY1 ${Me.Y}
	/varset StuckSpamTimerSet 5s
	|----------------------------------------------------------------
	|/echo (${Int[${Me.X}]}==${OutX1}) && (${Int[${Me.Y}]}==${OutY1})
	|----------------------------------------------------------------
	/if (${Debugging}) /echo Sub SetLoc Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckCasting
| --------------------------------------------------------------------------------------------
Sub CheckCasting
	/if (${Debugging}) /echo Sub CheckCasting Entry

	|-------------------------
	:CheckCastingNow
	/if (${Me.Casting.ID}) {
		/message \ag-- Waiting to stop casting.
		/delay 1s !${Me.Casting.ID}
		/goto :CheckCastingNow
		/message \ag-- I am done casting.
		/delay 1s
	}
	|-------------------------

	/if (${Debugging}) /echo Sub CheckCasting Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckStuck
| --------------------------------------------------------------------------------------------
Sub CheckStuck
	/if (${Debugging}) /echo Sub CheckStuck Entry
	/if (${Me.Stunned} || !${Navigation.Active}) /return
	/if (${StuckSpamTrigger}) /return 
	|/echo ${Math.Distance[${OutY1},${OutX1}]}
	/if (${Math.Distance[${OutY1},${OutX1}]} < 20) {
		/varcalc StuckCountOut (${StuckCountOut})+1
		/if (${StuckCountOut}>6) /message \arStuck ${StuckCountOut}
		/if (${Me.ActiveDisc.Name.Equal[Frenzied Resolve Discipline]}) /stopdisc
		/if (${StuckCountOut}>6) {
			/call doorclick 
			/if (${UseBeep}) {
			/beep
			/delay 1
			/beep
			}
			/call doorclick 
			}
		/varset StuckSpamTrigger 1
	} else { 
		/varset StuckCountOut 0
		}
	/if (${StuckCountOut}>=8) {
				/message \ayThink I'm stuck... \agAttempting to get unstuck...
				/call Stuck
				/varset StuckCountOut 0				
		}	
	/if (${Debugging}) /echo Sub CheckStuck Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Stuck
| --------------------------------------------------------------------------------------------
sub Stuck
/if (${Debugging}) /echo Sub Stuck Entry
/if (${StuckSwitch}) {
	/if (${Debugging}) /echo Hide Corpse STUCK
	/hidecorpse all
	/call BackUp
	/varset myTargetID 0			
	/varset StuckSwitch 0
	/varset StuckCountOut 0
	} else {
		/call DoorClick
		/varset StuckSwitch 1
		/varset StuckCountOut 0
		/varset courseCorrection 0
		/if (${Debugging}) /echo Hide Corpse STUCK
		/hidecorpse none
		}
/if (${Debugging}) /echo Sub Stuck Exit
/return
| --------------------------------------------------------------------------------------------
  
| --------------------------------------------------------------------------------------------
| SUB: BackUp
| --------------------------------------------------------------------------------------------
Sub BackUp
	/if (${Debugging}) /echo Sub Backup Entry
    /declare strafedir string local
	/target clear
	|/call DoorClick
	/if (${Navigation.Active}) /nav pause
	/if (${Me.FeetWet}) {
		/keypress down hold 
		/delay 10
		/keypress PAGE_UP hold
		/delay 20
		/keypress up hold
		/keypress right hold
		/delay 10
		/keypress left 
		/keypress down
		/keypress PAGE_DOWN
	}
	/keypress back hold
	/delay 20
	/varset myTargetID 0
	/keypress back
	/if (${Math.Rand[2]}) {
		/varset strafedir STRAFE_LEFT
	} else {
		/varset strafedir STRAFE_RIGHT
	}
	/keypress ${strafedir} hold
	/delay 20
	/keypress ${strafedir}
	/delay 10
	/keypress forward hold
	/delay 10
	/keypress forward
	|/if (!${Navigation.Active}) /nav pause
	/if (${Debugging}) /echo Sub Backup Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: DoorClick
| --------------------------------------------------------------------------------------------
Sub DoorClick 
/if (${Debugging}) /echo Sub DoorClick Entry
	/doortarget
	/delay 1s
	/click left door
/if (${Debugging}) /echo Sub DoorClick Exit	
/return 
| --------------------------------------------------------------------------------------------

|--------------------------------------------------------
|Group2Me
|--------------------------------------------------------
Sub Group2Me
/if (${Debugging}) /echo Sub Group2Me Entry
	|------------ KEEP AS SINGLE NOT GROUP COMMAND 	!
	/e3bca /nav id ${Me.ID}
	|------------ KEEP AS SINGLE NOT GROUP
/if (${Debugging}) /echo Sub Group2Me Exit
/return
|--------------------------------------------------------

|--------------------------------------------------------
| INIChange
|--------------------------------------------------------
Sub INIChange(Section,Key,Value)
/if (${Debugging}) /echo Sub INIChange Entry
	/ini "${Settings}" "${Section}" "${Key}" "${Value}"
/if (${Debugging}) /echo Sub INIChange Exit	
/return
|--------------------------------------------------------

|--------------------------------------------------------
| IsNumber
|--------------------------------------------------------
|Thanks to Kaen01 for his assistance with compressing my IsNumber sub to from 13 lines to 5 lines so that I could compress it to 4 lines.
Sub IsNumber(data)
/if (${Debugging}) /echo Sub IsNumber Entry
	/declare temp int local ${data}
	/if (${data.Compare[${temp}]}) /return FALSE
/if (${Debugging}) /echo Sub IsNumber Exit
/return TRUE
|--------------------------------------------------------

|--------------------------------------------------------
| MoveFwd
|--------------------------------------------------------
Sub MoveFwd
/if (${Debugging}) /echo Sub MoveFwd Entry
	/delay 2s
	/keypress forward hold
	/delay 3s
	/keypress forward
	/delay 1s
/if (${Debugging}) /echo Sub MoveFwd Exit
/return
|--------------------------------------------------------

|--------------------------------------------------------
| Refresh
|--------------------------------------------------------
Sub Refresh
/if (${Debugging}) /echo Sub Refresh Entry
/if (${Debugging}) /echo Calling Refresh
	/keypress F2
	/delay 2s
	/keypress F3
	/delay 2s
	/keypress F4
	/delay 2s
	/keypress F5
	/delay 2s
	/keypress F6
	/delay 2s
	/squelch /target clear
	/if (${Debugging}) /echo Sub Refresh Exit
/return
|--------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GenerateList
| --------------------------------------------------------------------------------------------
Sub GenerateList
	/if (${Debugging}) /echo Sub GenerateList Entry
		
	/declare i int local
	/message \ayGetting \am[\atNamed Mobs\am]\ay currently up in: \am[\at${Zone}\am]\ay.
	/if (!${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},Ignored].Length}) /ini "E3LDoN_MobIgnored.ini" "${Zone.ShortName}" "Ignored" "|"
	/for i 1 to ${SpawnCount[npc named]}
		/if (${NearestSpawn[${i},npc named].Name.NotEqual[NULL]}) {
			/if (!${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},NamedList].Find[${NearestSpawn[${i},npc named].CleanName}]} && !${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},Ignored].Find[${NearestSpawn[${i},NPC named].CleanName}]}) {
				/if (${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},NamedList].Length} < 1900) {	
					/message \ayFound - \ar${NearestSpawn[${i},npc named].CleanName}
					/ini "E3LDoN_MobIgnored.ini" "${Zone.ShortName}" "NamedList" "${If[${Bool[${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},NamedList]}]},${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},NamedList]},]}${NearestSpawn[${i},npc named].CleanName}|"
				} else {
					/message The Named list was too large and was cut short.
					/break
				}
			}
		}
	/next i
	/message \ayGetting \am[\atObjects\am]\ay currently up in: \am[\at${Zone}\am]\ay.
	/if (!${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},Objects].Length}) /ini "E3LDoN_MobIgnored.ini" "${Zone.ShortName}" "Objects" "|"
	/for i 1 to ${SpawnCount[Object]}
		/if (${NearestSpawn[${i},Object].Name.NotEqual[NULL]}) {
			/if (!${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},Objects].Find[${NearestSpawn[${i},Object].CleanName}]} && !${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},Ignored].Find[${NearestSpawn[${i},Object].CleanName}]}) {
				/if (${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},Objects].Length} < 1900) {
					/message \ayFound - \ar${NearestSpawn[${i},Object].CleanName}
					/ini "E3LDoN_MobIgnored.ini" "${Zone.ShortName}" "Objects" "${If[${Bool[${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},Objects]}]},${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},Objects]},]}${NearestSpawn[${i},Object].CleanName}|"
				} else {
					/message The Objects list was too large and was cut short.
					/break
				}
			}
		}
	/next i
	/message \ayGetting \am[\atNPCs\am]\ay currently up in: \am[\at${Zone}\am]\ay.
	/if (!${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},NPCs].Length}) /ini "E3LDoN_MobIgnored.ini" "${Zone.ShortName}" "NPCs" "|"
	/for i 1 to ${SpawnCount[npc]}
		/if (${NearestSpawn[${i},NPC].Name.NotEqual[NULL]} && !${NearestSpawn[${i},NPC].Named}) {
			/if (!${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},NPCs].Find[${NearestSpawn[${i},NPC].CleanName}]} && !${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},NamedList].Find[${NearestSpawn[${i},NPC].CleanName}]} && !${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},Ignored].Find[${NearestSpawn[${i},NPC].CleanName}]}) {
				/if (${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},NPCs].Length} < 1900) {
					/message \ayFound - \ar${NearestSpawn[${i},NPC].CleanName}
					/ini "E3LDoN_MobIgnored.ini" "${Zone.ShortName}" "NPCs" "${If[${Bool[${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},NPCs]}]},${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},NPCs]},]}${NearestSpawn[${i},NPC].CleanName}|"
				} else {
					/message The NPCs list was too large and was cut short.
					/break
				}
			}
		}
	/next i
	/message \agDone, list is stored in E3LDoN_MobIgnored.ini
	
	|------------------
	/message ==================================================================
	/call SetPetNoAlert
	/message ==================================================================
	|------------------
	
	/if (${Debugging}) /echo Sub GenerateList Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: SetPetNoAlert
| --------------------------------------------------------------------------------------------
Sub SetPetNoAlert
	/if (${Debugging}) /echo Sub SetPetNoAlert Entry

	/declare x 								int local

	| --- CLEAR ALERT list ---|
	/if (${Alert[1].Size}>0) {
		/message \ayClearing ALERTLIST \am[\ay1\am]
		/squelch /alert clear 1
		/message ==================================================================	
	}
	| --- CLEAR ALERT list ---|
	
	|-----
    /for x 0 to ${Group.Members}
		/if (${Group.Member[${x}].ID}>0) {
			/message \atAdding \am${Group.Member[${x}].CleanName} \ay(\aoID:${Group.Member[${x}].ID}\ay) \atto \arNOALERT \atlist \am[\ay1\am]\at.
			/squelch /alert add 1 id ${Group.Member[${x}].ID}
		}
    /next x
	|-----

	|-----
    /for x 0 to ${Group.Members}
		/if (${Group.Member[${x}].Pet.ID}>0) {
			/message \atAdding \am${Group.Member[${x}].CleanName}'s \agpet \ay(\ao${Group.Member[${x}].Pet.CleanName} \ayID:${Group.Member[${x}].Pet.ID}\ay) \atto \arNOALERT \atlist \am[\ay1\am]\at.
			/squelch /alert add 1 id ${Group.Member[${x}].Pet.ID}
		}
    /next x
	|-----

	/if (${Alert[1].Size}>0) {
		/message ==================================================================	
		/message \arALERTLIST \am[\ay1\am] \arhas \ay(\at${Alert[1].Size}\ay) \arentries in it.
	}

	/if (${Debugging}) /echo Sub SetPetNoAlert Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Bind_E3LDONCommand
| --------------------------------------------------------------------------------------------
Sub Bind_E3LDONCommand
	/if (${Debugging}) /echo Sub Bind_E3LDONCommand Entry
	|If Param0 isn't defined display help. 
	/if (!${Defined[Param0]}) {
		/call Help
	}
	|If the user provided a parameter then lets decide what to do with it. 
	/if (${Defined[Param0]}) {
		|----------------
		|----------------
		|Lets make sure this parameter isn't a number.
		/call IsNumber "${Param0}"
		|If it's not a number go ahead and see what they want. 
		/if (${Macro.Return.Equal[FALSE]}) {
			|If /E3LDON help
			/if (${Param0.Equal[help]}) {
				/call Help
			|----------------
			|----------------
			|If /E3LDON radius
			} else /if (${Param0.Equal[radius]}) {
				/if (!${Defined[Param1]}) {
					/message \aoRadius to search for mobs\aw: \ag${PullRange}
				} else {
					/call IsNumber "${Param1}"
					/if (${Macro.Return.Equal[TRUE]}) {
						/varset PullRange ${Param1}
						/squelch /mapfilter castradius ${PullRange}
						/message \atRadius set to: ${Param1}\aw.
					} else {
						/message \ar${Param1} is not a valid option for Radius. \n/E3LDON radius value, where value is a number. 
					}
				}
			|----------------
			|----------------
			|If /E3LDON zradius
			} else /if (${Param0.Equal[zradius]}) {
				/if (!${Defined[Param1]}) {
					/message \aoZRadius to search for mobs\aw: \ag${ZRadius}\aw.
				} else {
					/call IsNumber "${Param1}"
					/if (${Macro.Return.Equal[TRUE]}) {
						/varset ZRadius ${Param1}
						/call IniChange "Pull" "Zradius" "${Param1}"
						/message \atZRadius set to: ${Param1}\aw.
					} else {
						/message \ar${Param1} is not a valid option for ZRadius. \n/E3LDON ZRadius value, where value is a number. 
					}
				}
			|----------------
			|----------------			
			|If /E3LDON Debug
			} else /if (${Param0.Equal[Debug]}) {
				/if (!${Defined[Param1]}) {
					/message \aoDebugging\aw: \ag${Debugging}\aw.
				} else {
					/call IsNumber "${Param1}"
					/if (${Macro.Return.Equal[TRUE]}) {
						/if (${Param1}==1) {
							/if (!${Debugging}) {
								/varset Debugging TRUE
								/call IniChange "General" "Debugging" "TRUE"
								/message \aoDebugging is now\aw: \agON\aw!
							} else {
								/message \arDebugging is already on. 
							}
						} else /if (${Param1} == 0) {
							/if (${Debugging}) {
								/varset Debugging FALSE
								/call IniChange "General" "Debugging" "FALSE"
								/message \aoDebugging is now\aw: \arOFF\aw!
							} else {
								/message \arDebugging is already off. 
							}
						} else {
							/message \arError\aw: \ap${Param1} \aris not a valid option for /E3LDON Debug
						}
					} else {
						/if (${Param1.Equal[on]}) {
							/varset Debugging TRUE
							/call IniChange "General" "Debugging" "TRUE"
							/message \aoDebugging is now\aw: \agON\aw!
						} else /if (${Param1.Equal[off]}) {
							/varset Debugging FALSE
							/call IniChange "General" "Debugging" "FALSE"
							/message \aoDebugging is now\aw: \arOFF\aw!
						} else {
							/message \arError\aw: \ap${Param1} \aris not a valid option for /E3LDON Debug
						} 
					}
				}
			|----------------
			|----------------
			|If /E3LDON HardMode
			} else /if (${Param0.Equal[hardmode]}) {
				/if (!${Defined[Param1]}) {
					/message \aoHardMode\aw: \ag${HardMode}
				} else {
					/call IsNumber "${Param1}"
					/if (${Macro.Return.Equal[TRUE]}) {
						/if (${Param1}==1) {
							/if (!${HardMode}) {
								/varset HardMode TRUE
								/call IniChange "General" "HardMode" "TRUE"
								/message \aoHardMode is now\aw: \agON!
							} else {
								/message \arHardMode is already on. 
							}
						} else /if (${Param1} == 0) {
							/if (${HardMode}) {
								/varset HardMode FALSE
								/call IniChange "General" "HardMode" "FALSE"
								/message \aoHardMode is now\aw: \arOFF!
							} else {
								/message \arHardMode is already off. 
							}
						} else {
							/message \arError\aw: \ap${Param1} \aris not a valid option for /E3LDON HardMode
						}
					} else {
						/if (${Param1.Equal[on]}) {
							/varset HardMode TRUE
							/call IniChange "General" "HardMode" "TRUE"
							/message \aoHardMode is now\aw: \agON!
						} else /if (${Param1.Equal[off]}) {
							/varset HardMode FALSE
							/call IniChange "General" "HardMode" "FALSE"
							/message \aoHardMode is now\aw: \arOFF!
						} else {
							/message \arError\aw: \ap${Param1} \aris not a valid option for /E3LDON HardMode
						} 
					}
				}
			|----------------
			|----------------
			|If /E3LDON SwarmPull
			} else /if (${Param0.Equal[SwarmPull]}) {
				/if (!${Defined[Param1]}) {
					/message \aoSwarmPull\aw: \ag${SwarmPull}
				} else {
					/call IsNumber "${Param1}"
					/if (${Macro.Return.Equal[TRUE]}) {
						/if (${Param1}==1) {
							/if (!${SwarmPull}) {
								/varset SwarmPull TRUE
								/call IniChange "General" "SwarmPull" "TRUE"
								/message \aoSwarmPull is now\aw: \agON!
							} else {
								/message \arSwarmPull is already on. 
							}
						} else /if (${Param1} == 0) {
							/if (${SwarmPull}) {
								/varset SwarmPull FALSE
								/call IniChange "General" "SwarmPull" "FALSE"
								/message \aoSwarmPull is now\aw: \arOFF!
							} else {
								/message \arSwarmPull is already off. 
							}
						} else {
							/message \arError\aw: \ap${Param1} \aris not a valid option for /E3LDON SwarmPull
						}
					} else {
						/if (${Param1.Equal[on]}) {
							/varset SwarmPull TRUE
							/call IniChange "General" "SwarmPull" "TRUE"
							/message \aoSwarmPull is now\aw: \agON!
						} else /if (${Param1.Equal[off]}) {
							/varset SwarmPull FALSE
							/call IniChange "General" "SwarmPull" "FALSE"
							/message \aoSwarmPull is now\aw: \arOFF!
						} else {
							/message \arError\aw: \ap${Param1} \aris not a valid option for /E3LDON SwarmPull
						} 
					}
				}
			|----------------	
			|----------------
			|If /E3LDON ThemeCheck
			} else /if (${Param0.Equal[ThemeCheck]}) {
				/if (!${Defined[Param1]}) {
					/message \aoThemeCheck\aw: \ag${ThemeCheck}
				} else {
					/call IsNumber "${Param1}"
					/if (${Macro.Return.Equal[TRUE]}) {
						/if (${Param1}==1) {
							/if (!${ThemeCheck}) {
								/varset ThemeCheck TRUE
								/call IniChange "General" "ThemeCheck" "TRUE"
								/message \aoThemeCheck is now\aw: \agON!
							} else {
								/message \arThemeCheck is already on. 
							}
						} else /if (${Param1} == 0) {
							/if (${ThemeCheck}) {
								/varset ThemeCheck FALSE
								/call IniChange "General" "ThemeCheck" "FALSE"
								/message \aoThemeCheck is now\aw: \arOFF!
							} else {
								/message \arThemeCheck is already off. 
							}
						} else {
							/message \arError\aw: \ap${Param1} \aris not a valid option for /E3LDON ThemeCheck
						}
					} else {
						/if (${Param1.Equal[on]}) {
							/varset ThemeCheck TRUE
							/call IniChange "General" "ThemeCheck" "TRUE"
							/message \aoThemeCheck is now\aw: \agON!
						} else /if (${Param1.Equal[off]}) {
							/varset ThemeCheck FALSE
							/call IniChange "General" "ThemeCheck" "FALSE"
							/message \aoThemeCheck is now\aw: \arOFF!
						} else {
							/message \arError\aw: \ap${Param1} \aris not a valid option for /E3LDON ThemeCheck
						} 
					}
				}
			|----------------			
			|----------------
			|If /E3LDON farmmob
			} else /if (${Param0.Equal[FarmMob]}) {
				/if (!${Defined[Param1]}) {
					/message \aoFarmMob search string\aw: \ag${FarmMob}\aw.
				} else {
					/varset FarmMob "${Param1}"
					/message \atFarmMob set to: ${Param1}\aw.
				}
			}
		} else {
			/call Help
		}
	}
	/if (${Debugging}) /echo Sub Bind_E3LDONCommand Exit
/return
