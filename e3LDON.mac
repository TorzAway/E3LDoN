| --------------------------------------------------------------------------------------------
|--------------------------------------------------------
 Sub Bind_AddToIgnore
	/alert add 1 ${Target.CleanName}
	/varset myTargetID 0
	/squelch /target clear
 /return 
|--------------------------------------------------------
|--------------------------------------------------------
Sub Bind_AddThisIgnore
	/alert add 1 ${Target.Name}
	/varset myTargetID 0
	/squelch /target clear
/return
|--------------------------------------------------------
|--------------------------------------------------------
Sub Bind_PermIgnore
	/alert add 1 ${Target.CleanName}
	/if (!${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},Ignored].Find[${Target.CleanName}]}) {
		/message \atAdding ${Target.CleanName} to E3LDoN_MobIgnored.ini for zone ${Zone.ShortName}
		/ini "E3LDoN_MobIgnored.ini" "${Zone.ShortName}" "Ignored" "${If[${Bool[${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},Ignored]}]},${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName},Ignored]},]}${Target.CleanName}|"
		/varset myTargetID 0
		/squelch /target clear
		/varset notkillable 0
	} else {
		/message \ar${Target.CleanName} is already on the permanent ignore list. Maybe you got aggro?
	}
/return
|--------------------------------------------------------
|--------------------------------------------------------
Sub Bind_AddThisIgnore
	/alert add 1 ${Target.Name}
	/varset myTargetID 0
	/squelch /target clear
/return
|--------------------------------------------------------
|--------------------------------------------------------
Sub Bind_showignored
	/message \au${Ini[E3LDoN_MobIgnored.ini,${Zone.ShortName,Ignored]}
/return
